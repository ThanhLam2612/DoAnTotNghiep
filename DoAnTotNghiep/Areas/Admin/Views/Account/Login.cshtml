@{
}
@{
    // Tắt Layout đi để trang này độc lập hoàn toàn, bao trọn màn hình
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập Quản trị - MyShop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background-color: #f4f6f9; /* Màu nền nhẹ nhàng, chuyên nghiệp */
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }

        .login-box {
            width: 100%;
            max-width: 400px;
            padding: 15px;
        }
    </style>
</head>
<body>

    <div class="login-box">
        <div class="card shadow border-0 rounded-3">
            <div class="card-header bg-dark text-white text-center py-4">
                <h3 class="fw-bold mb-0">⚙️ HỆ THỐNG QUẢN TRỊ</h3>
            </div>
            <div class="card-body p-4 p-md-5">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger text-center fw-bold small mb-4">
                        @ViewBag.Error
                    </div>
                }

                <form asp-area="Admin" asp-controller="Account" asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tài khoản Quản trị</label>
                        <input type="text" name="username" class="form-control form-control-lg" placeholder="Nhập username..." required autofocus />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Mật khẩu</label>
                        <input type="password" name="password" class="form-control form-control-lg" placeholder="Nhập mật khẩu..." required />
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">
                        ĐĂNG NHẬP HỆ THỐNG
                    </button>
                </form>

            </div>
        </div>
        <div class="text-center mt-3">
            <a href="/" class="text-decoration-none text-muted fw-bold">⬅ Quay về trang mua sắm</a>
        </div>
    </div>

</body>
</html>