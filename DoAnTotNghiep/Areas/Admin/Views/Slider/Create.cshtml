@model DoAnTotNghiep.Models.Slider

@{
    ViewData["Title"] = "Thêm Slide Mới";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">Tạo Slide Trang Chủ</h2>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold shadow-sm rounded-pill px-4">Quay lại danh sách</a>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

        <div class="row g-4">

            <div class="col-md-6">
                <div class="card shadow-sm border-0 rounded-4 h-100">
                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                        <h5 class="fw-bold text-primary"><i class="bi bi-fonts"></i> Nội dung hiển thị</h5>
                    </div>
                    <div class="card-body p-4">

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold">Tiêu đề chính (Chữ to)</label>
                            <input asp-for="Title" class="form-control" placeholder="" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả ngắn (Chữ nhỏ)</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder=""></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="mb-3 mt-4 bg-light p-3 rounded border">
                            <div class="form-check form-switch fs-5">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" id="IsActiveSwitch" checked>
                                <label class="form-check-label fw-bold ms-2 mt-1 text-dark" for="IsActiveSwitch">Bật hiển thị ngay lập tức</label>
                            </div>
                            <div class="small text-muted mt-2">
                                <i class="fas fa-info-circle text-primary"></i> <i>Slide mới sẽ được hệ thống tự động xếp xuống cuối cùng. Bạn có thể tráo đổi vị trí sau khi lưu.</i>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm border-0 rounded-4 h-100 border-start border-primary border-4">
                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                        <h5 class="fw-bold text-primary"><i class="bi bi-image"></i> Hình ảnh Slide <span class="text-danger">*</span></h5>
                        <small class="text-muted">Khuyên dùng ảnh tỷ lệ 16:9 (VD: 1920x1080px) để hiển thị đẹp nhất.</small>
                    </div>
                    <div class="card-body p-4 text-center">

                        <div class="mb-4">
                            <input type="file" name="imageUpload" id="imageUpload" class="form-control form-control-lg border-primary shadow-sm" accept="image/*" onchange="previewImage(event)" />
                        </div>

                        <div id="imagePreviewContainer" class="border rounded-3 p-2 bg-light shadow-inner" style="display: none;">
                            <p class="text-muted fw-bold mb-2 small"><i class="fas fa-eye"></i> Xem trước ảnh sẽ hiển thị:</p>
                            <img id="imagePreview" src="#" alt="Preview" class="img-fluid rounded" style="max-height: 250px; object-fit: contain;" />
                        </div>

                        <div id="uploadPlaceholder" class="border rounded-3 p-5 bg-light border-dashed">
                            <i class="bi bi-cloud-arrow-up text-secondary opacity-50" style="font-size: 4rem;"></i>
                            <h5 class="text-secondary opacity-50 mt-2">Chưa chọn hình ảnh nào</h5>
                        </div>

                    </div>
                    <div class="card-footer bg-white border-top-0 p-4">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold w-100 shadow">
                            <i class="fas fa-save me-2"></i> LƯU VÀ THÊM SLIDE
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

<style>
    .border-dashed {
        border-style: dashed !important;
        border-width: 2px !important;
        border-color: #dee2e6 !important;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function previewImage(event) {
            var input = event.target;
            var reader = new FileReader();

            reader.onload = function(){
                var dataURL = reader.result;
                var output = document.getElementById('imagePreview');
                var container = document.getElementById('imagePreviewContainer');
                var placeholder = document.getElementById('uploadPlaceholder');

                output.src = dataURL;
                container.style.display = 'block';
                placeholder.style.display = 'none';
            };

            if(input.files && input.files[0]) {
                reader.readAsDataURL(input.files[0]);
            } else {
                document.getElementById('imagePreviewContainer').style.display = 'none';
                document.getElementById('uploadPlaceholder').style.display = 'block';
            }
        }
    </script>
}