@model IEnumerable<DoAnTotNghiep.Models.Promotion>

@{
    ViewData["Title"] = "Quản lý Khuyến mãi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4 mb-5">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show fw-bold shadow-sm">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-danger m-0">Chiến dịch Khuyến mãi</h2>
        <a asp-action="Create" class="btn btn-danger fw-bold shadow-sm rounded-pill px-4">
            Tạo chiến dịch mới
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4 bg-light">
        <div class="card-body p-3">
            <form asp-action="Index" method="get">
                @{
                    string currentStatus = ViewBag.Status as string;
                }
                <div class="row g-2 align-items-end">

                    <div class="col-md-5">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">Tìm kiếm</label>
                        <input type="text" name="searchString" class="form-control" value="@ViewBag.SearchString" placeholder="Nhập tên chiến dịch hoặc mô tả...">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">Thiết lập trạng thái</label>
                        <select name="status" class="form-select">
                            <option value="">-- Tất cả trạng thái --</option>
                            <option value="ongoing" selected="@(currentStatus == "ongoing")">Đang diễn ra</option>
                            <option value="upcoming" selected="@(currentStatus == "upcoming")">Sắp diễn ra</option>
                            <option value="ended" selected="@(currentStatus == "ended")">Đã kết thúc</option>
                            <option value="disabled" selected="@(currentStatus == "disabled")">Đã tắt</option>
                        </select>
                    </div>

                    <div class="col-md-3 d-flex gap-2">
                        <button type="submit" class="btn btn-danger fw-bold flex-grow-1 shadow-sm">Lọc dữ liệu</button>

                        @if (!string.IsNullOrEmpty(ViewBag.SearchString) || !string.IsNullOrEmpty(currentStatus))
                        {
                            <a asp-action="Index" class="btn btn-outline-secondary fw-bold px-3 shadow-sm" title="Xóa bộ lọc"><i class="fa-solid fa-xmark"></i></a>
                        }
                    </div>

                </div>
            </form>
        </div>
    </div>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-danger text-white">
                        <tr>
                            <th class="py-3 px-4" style="width: 25%;">Tên chiến dịch</th>
                            <th class="py-3 text-center" style="width: 15%;">Mức giảm</th>
                            <th class="py-3 text-center" style="width: 20%;">Thời gian áp dụng</th>
                            <th class="py-3 text-center" style="width: 15%;">Biến thể áp dụng</th>
                            <th class="py-3 text-center" style="width: 10%;">Tình trạng</th>
                            <th class="py-3 text-center" style="width: 15%;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                var now = DateTime.Now;
                                string statusBadge = "";
                                if (!item.IsActive)
                                {
                                    statusBadge = "<span class='badge bg-secondary'>Đã tắt</span>";
                                }
                                else if (now < item.StartDate)
                                {
                                    statusBadge = "<span class='badge bg-warning text-dark'>Sắp diễn ra</span>";
                                }
                                else if (now >= item.StartDate && now <= item.EndDate)
                                {
                                    statusBadge = "<span class='badge bg-success shadow-sm'>Đang diễn ra</span>";
                                }
                                else
                                {
                                    statusBadge = "<span class='badge bg-dark'>Đã kết thúc</span>";
                                }

                                // TÍNH TOÁN KHOẢNG GIẢM GIÁ (TỪ X% ĐẾN Y%)
                                string discountDisplay = "0%";
                                if (item.PromotionVariants != null && item.PromotionVariants.Any())
                                {
                                    var minDiscount = item.PromotionVariants.Min(p => p.DiscountPercent);
                                    var maxDiscount = item.PromotionVariants.Max(p => p.DiscountPercent);

                                    if (minDiscount == maxDiscount)
                                    {
                                        discountDisplay = $"{minDiscount}%";
                                    }
                                    else
                                    {
                                        discountDisplay = $"{minDiscount}% ~ {maxDiscount}%";
                                    }
                                }

                                <tr>
                                    <td class="px-4 fw-bold text-dark">
                                        @item.PromotionName
                                        <div class="small text-muted fw-normal">@item.Description</div>
                                    </td>

                                    <td class="text-center fw-bold text-danger fs-6">
                                        @discountDisplay
                                    </td>

                                    <td class="text-center small fw-bold text-muted">
                                        @item.StartDate.ToString("dd/MM/yyyy") <br />
                                        <i class="bi bi-arrow-down"></i> <br />
                                        @item.EndDate.ToString("dd/MM/yyyy")
                                    </td>

                                    <td class="text-center fw-bold text-primary">
                                        <span class="badge bg-light text-primary border border-primary">
                                            @(item.PromotionVariants?.Count ?? 0) cấu hình
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        @Html.Raw(statusBadge)
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Edit" asp-route-id="@item.PromotionId" class="btn btn-sm btn-outline-primary" title="Sửa"><i class="fas fa-edit"></i></a>
                                            <a asp-action="Delete" asp-route-id="@item.PromotionId" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn chiến dịch @item.PromotionName không?');" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted fw-bold">Chưa có chiến dịch nào!</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    string filterStatus = ViewBag.Status as string;

    <nav aria-label="Page navigation" class="mt-4 mb-5">
        <ul class="pagination justify-content-center shadow-sm">

            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link fw-bold text-danger" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-searchString="@ViewBag.SearchString"
                   asp-route-status="@filterStatus">❮ Trước</a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link fw-bold @(i == ViewBag.CurrentPage ? "bg-danger border-danger text-white" : "text-danger")" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-searchString="@ViewBag.SearchString"
                       asp-route-status="@filterStatus">@i</a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link fw-bold text-danger" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-searchString="@ViewBag.SearchString"
                   asp-route-status="@filterStatus">Sau ❯</a>
            </li>

        </ul>
    </nav>
}

<style>
    .table-hover tbody tr:hover {
        background-color: #fff5f5;
        transition: background-color 0.2s ease-in-out;
    }
</style>