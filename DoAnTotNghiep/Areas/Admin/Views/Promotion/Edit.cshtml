@model DoAnTotNghiep.Models.Promotion
@{
    ViewData["Title"] = "Chỉnh sửa chiến dịch khuyến mãi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var products = ViewBag.Products as List<DoAnTotNghiep.Models.Product>;
}

<div class="container-fluid mb-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-xl-10">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold text-primary m-0"><i class="fas fa-edit me-2"></i>Chỉnh Sửa: <span class="text-dark">@Model.PromotionName</span></h3>
                <a asp-action="Index" class="btn btn-outline-secondary fw-bold shadow-sm rounded-pill px-4">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại
                </a>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger shadow-sm border-0 rounded-3 mb-4">
                    <i class="fas fa-exclamation-triangle me-2"></i> <strong>Có lỗi xảy ra:</strong>
                    <div asp-validation-summary="All" class="mt-2 mb-0 small"></div>
                </div>
            }

            <form asp-action="Edit" method="post" id="promoForm">
                <input type="hidden" asp-for="PromotionId" />

                <div class="card shadow-sm border-0 rounded-4 mb-4 border-start border-danger border-4">
                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                        <h5 class="fw-bold text-dark m-0">1. Thông tin chiến dịch</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-4">
                            <div class="col-md-12">
                                <label class="form-label fw-bold text-muted small text-uppercase">Tên chương trình: <span class="text-danger">*</span></label>
                                <input asp-for="PromotionName" class="form-control form-control-lg shadow-sm fs-6" required />
                                <span asp-validation-for="PromotionName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small text-uppercase">Ngày bắt đầu: <span class="text-danger">*</span></label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white text-muted"><i class="far fa-calendar-alt"></i></span>
                                    <input asp-for="StartDate" class="form-control" type="date" required />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small text-uppercase">Ngày kết thúc: <span class="text-danger">*</span></label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white text-muted"><i class="far fa-calendar-check"></i></span>
                                    <input asp-for="EndDate" class="form-control" type="date" required />
                                </div>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-bold text-muted small text-uppercase">Mô tả chương trình (Tùy chọn):</label>
                                <textarea asp-for="Description" class="form-control shadow-sm" rows="3"></textarea>
                            </div>

                            <div class="col-md-12">
                                <div class="bg-light p-3 rounded border d-flex align-items-center justify-content-between">
                                    <div>
                                        <div class="fw-bold text-dark">Trạng thái chiến dịch</div>
                                        <div class="small text-muted">Bật để khách hàng có thể nhìn thấy khuyến mãi ngay lập tức (nếu đã đến ngày).</div>
                                    </div>
                                    <div class="form-check form-switch fs-4 m-0">
                                        <input class="form-check-input" type="checkbox" asp-for="IsActive" style="cursor: pointer;">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0 rounded-4 border-start border-primary border-4">
                    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                        <h5 class="fw-bold text-dark m-0">2. Chọn Sản phẩm & Cấu hình giảm giá</h5>
                    </div>
                    <div class="card-body p-4">

                        <div class="row align-items-end bg-light p-3 rounded-3 border mb-4 mx-0">
                            <div class="col-md-8 position-relative search-container mb-3 mb-md-0">
                                <label class="form-label fw-bold text-primary small"><i class="fas fa-search me-1"></i>Tìm thêm sản phẩm vào chiến dịch:</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white text-primary border-primary"><i class="fas fa-box-open"></i></span>
                                    <input type="text" id="productSearchInput" class="form-control border-primary border-start-0 ps-0" placeholder="Nhập tên sản phẩm..." autocomplete="off">
                                </div>
                                <input type="hidden" id="selectedProductId" value="">

                                <ul class="list-group position-absolute w-100 shadow-lg d-none mt-1 border-0" id="productDropdown" style="max-height: 250px; overflow-y: auto; z-index: 1050; border-radius: 0.5rem;">
                                    @if (products != null)
                                    {
                                        foreach (var p in products)
                                        {
                                            <li class="list-group-item list-group-item-action product-item cursor-pointer border-bottom px-3 py-2" data-id="@p.ProductId">
                                                <span class="fw-bold text-dark">@p.ProductName</span>
                                            </li>
                                        }
                                    }
                                </ul>
                            </div>
                            <div class="col-md-4">
                                <button type="button" class="btn btn-primary w-100 fw-bold shadow-sm" id="btnLoadVariants">
                                    <i class="fas fa-download me-2"></i> TẢI BIẾN THỂ
                                </button>
                            </div>
                        </div>

                        <div class="table-responsive border rounded-3 shadow-sm">
                            <table class="table table-hover align-middle mb-0" id="variantsTable">
                                <thead class="table-light">
                                    <tr class="text-muted small text-uppercase fw-bold">
                                        <th class="px-4">Sản Phẩm / Cấu Hình</th>
                                        <th class="text-end" style="width: 15%;">Giá Gốc</th>
                                        <th class="text-center" style="width: 20%;">% Giảm Giá</th>
                                        <th class="text-end" style="width: 18%;">Giá Mới</th>
                                        <th class="text-center" style="width: 8%;">Hủy</th>
                                    </tr>
                                </thead>
                                <tbody id="variantBody">

                                    @if (Model.PromotionVariants != null && Model.PromotionVariants.Any())
                                    {
                                        foreach (var pv in Model.PromotionVariants)
                                        {
                                            var v = pv.ProductVariant;
                                            if (v == null) continue;

                                            var productName = v.Product?.ProductName ?? "Sản phẩm không xác định";

                                            // Nối các thuộc tính lại thành Tên Biến Thể
                                            var attrList = v.AttributeValues?
                                            .Where(a => a.PredefinedAttributeValue != null)
                                            .Select(a => a.PredefinedAttributeValue.Value)
                                            .ToList();
                                            var variantName = (attrList != null && attrList.Any()) ? string.Join(" - ", attrList) : "Bản tiêu chuẩn";

                                            var basePrice = v.Price;
                                            var discount = pv.DiscountPercent;
                                            var salePrice = basePrice - (basePrice * discount / 100m);

                                            <tr id="row_@v.VariantId" class="bg-white">
                                                <td class="px-4 py-3">
                                                    <input type="hidden" name="selectedVariants" value="@v.VariantId" />
                                                    <div class="fw-bold text-dark mb-1">@productName</div>
                                                    <span class="badge bg-light text-primary border border-primary-subtle px-2 py-1">@variantName</span>
                                                </td>
                                                <td class="text-end fw-bold text-secondary align-middle" id="basePrice_@v.VariantId" data-price="@basePrice">
                                                    @basePrice.ToString("#,##0") đ
                                                </td>
                                                <td class="align-middle px-3">
                                                    <div class="input-group shadow-sm">
                                                        <input type="number" name="discounts" class="form-control border-danger text-danger fw-bold text-center discount-input"
                                                               value="@discount" min="0" max="100" data-id="@v.VariantId" />
                                                        <span class="input-group-text bg-danger text-white border-danger fw-bold">%</span>
                                                    </div>
                                                </td>
                                                <td class="text-end fw-bold text-success fs-5 align-middle" id="salePrice_@v.VariantId">
                                                    @salePrice.ToString("#,##0") đ
                                                </td>
                                                <td class="text-center align-middle">
                                                    <button type="button" class="btn btn-sm btn-outline-danger btn-remove-row rounded-circle shadow-sm" data-id="@v.VariantId" title="Xóa khỏi danh sách">
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr id="emptyRow">
                                            <td colspan="5" class="text-center py-5 text-muted">
                                                <i class="fas fa-inbox fs-1 text-secondary opacity-25 mb-3 d-block"></i>
                                                <span class="fw-bold">Chưa có sản phẩm nào được chọn.</span><br />
                                                <small>Vui lòng tìm kiếm sản phẩm ở phía trên và bấm "Tải Biến thể"</small>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-4">
                    <a asp-action="Index" class="btn btn-light border fw-bold rounded-pill px-5 py-2 shadow-sm">Hủy bỏ</a>
                    <button type="submit" class="btn btn-primary shadow-sm fw-bold rounded-pill py-2 px-5" id="btnSubmit">
                        <i class="fas fa-save me-2"></i> LƯU CẬP NHẬT CHIẾN DỊCH
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<style>
    .cursor-pointer {
        cursor: pointer;
    }

    .product-item {
        transition: background-color 0.2s ease;
    }

        .product-item:hover {
            background-color: #f8f9fa;
            color: #0d6efd;
        }

    /* Tùy chỉnh thanh cuộn cho dropdown mượt mà */
    #productDropdown::-webkit-scrollbar {
        width: 6px;
    }

    #productDropdown::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    #productDropdown::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 10px;
    }

        #productDropdown::-webkit-scrollbar-thumb:hover {
            background: #a8a8a8;
        }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Mảng lưu ID của các biến thể ĐÃ CÓ TRONG DATABASE để JS biết và không add trùng
        let addedVariantIds = [
            @if (Model.PromotionVariants != null && Model.PromotionVariants.Any())
            {
                    @Html.Raw(string.Join(",", Model.PromotionVariants.Select(pv => pv.VariantId)))
            }
        ];

        $(document).ready(function () {

            // ========================================================
            // LOGIC TÌM KIẾM SẢN PHẨM TRỰC TIẾP TRÊN GIAO DIỆN
            // ========================================================
            $('#productSearchInput').on('click', function() {
                $(this).select();
            });

            $('#productSearchInput').on('input', function() {
                let keyword = $(this).val().toLowerCase().trim();
                $('#selectedProductId').val('');

                if (keyword.length > 0) {
                    $('#productDropdown').removeClass('d-none');
                    let hasMatch = false;

                    $('.product-item').each(function() {
                        let text = $(this).text().toLowerCase();
                        if (text.includes(keyword)) {
                            $(this).removeClass('d-none');
                            hasMatch = true;
                        } else {
                            $(this).addClass('d-none');
                        }
                    });

                    if (!hasMatch) {
                        $('#productDropdown').addClass('d-none');
                    }
                } else {
                    $('#productDropdown').addClass('d-none');
                }
            });

            $('.product-item').on('click', function() {
                let id = $(this).data('id');
                let name = $(this).text().trim();

                $('#selectedProductId').val(id);
                $('#productSearchInput').val(name);
                $('#productDropdown').addClass('d-none');
            });

            $(document).on('click', function(e) {
                if (!$(e.target).closest('.search-container').length) {
                    $('#productDropdown').addClass('d-none');
                }
            });

            // ========================================================
            // XỬ LÝ BẤM NÚT TẢI BIẾN THỂ
            // ========================================================
            $('#btnLoadVariants').click(function () {
                let productId = $('#selectedProductId').val();
                let productName = $('#productSearchInput').val();

                if (!productId) {
                    alert("Vui lòng tìm kiếm và chọn một sản phẩm từ danh sách gợi ý!");
                    $('#productSearchInput').focus();
                    return;
                }

                $.ajax({
                    url: '@Url.Action("GetVariantsByProduct", "Promotion", new { area = "Admin" })',
                    type: 'GET',
                    data: { productId: productId },
                    success: function (data) {
                        if (data && data.length > 0) {
                            $('#emptyRow').remove();
                            let hasNew = false;

                            data.forEach(v => {
                                if (addedVariantIds.includes(v.variantId)) return;

                                addedVariantIds.push(v.variantId);
                                hasNew = true;

                                let priceFmt = new Intl.NumberFormat('vi-VN').format(v.price) + ' đ';

                                // HTML Dòng biến thể mới y hệt trang Create
                                let tr = `
                                <tr id="row_${v.variantId}" class="bg-white">
                                    <td class="px-4 py-3">
                                        <input type="hidden" name="selectedVariants" value="${v.variantId}" />
                                        <div class="fw-bold text-dark mb-1">${productName}</div>
                                        <span class="badge bg-light text-primary border border-primary-subtle px-2 py-1">${v.variantName || 'Bản tiêu chuẩn'}</span>
                                    </td>
                                    <td class="text-end fw-bold text-secondary align-middle" id="basePrice_${v.variantId}" data-price="${v.price}">
                                        ${priceFmt}
                                    </td>
                                    <td class="align-middle px-3">
                                        <div class="input-group shadow-sm">
                                            <input type="number" name="discounts" class="form-control border-danger text-danger fw-bold text-center discount-input"
                                                   value="0" min="0" max="100" data-id="${v.variantId}" />
                                            <span class="input-group-text bg-danger text-white border-danger fw-bold">%</span>
                                        </div>
                                    </td>
                                    <td class="text-end fw-bold text-success fs-5 align-middle" id="salePrice_${v.variantId}">
                                        ${priceFmt}
                                    </td>
                                    <td class="text-center align-middle">
                                        <button type="button" class="btn btn-sm btn-outline-danger btn-remove-row rounded-circle shadow-sm" data-id="${v.variantId}" title="Xóa khỏi danh sách">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </td>
                                </tr>`;

                                $('#variantBody').append(tr);
                            });

                            if (!hasNew) {
                                alert("Tất cả cấu hình của sản phẩm này đã được thêm vào bảng!");
                            }

                            $('#productSearchInput').val('');
                            $('#selectedProductId').val('');

                        } else {
                            alert("Sản phẩm này chưa được thiết lập biến thể cấu hình nào!");
                        }
                    },
                    error: function () {
                        alert("Có lỗi xảy ra khi lấy dữ liệu cấu hình. Vui lòng thử lại!");
                    }
                });
            });

            // ========================================================
            // XỬ LÝ GÕ % TỰ ĐỘNG TÍNH TIỀN
            // ========================================================
            $(document).on('input', '.discount-input', function () {
                let vid = $(this).data('id');
                let discount = parseInt($(this).val()) || 0;

                if (discount < 0) { discount = 0; $(this).val(0); }
                if (discount > 100) { discount = 100; $(this).val(100); }

                let basePrice = parseFloat($(`#basePrice_${vid}`).data('price'));
                let salePrice = basePrice - (basePrice * discount / 100);

                $(`#salePrice_${vid}`).text(new Intl.NumberFormat('vi-VN').format(salePrice) + ' đ');
            });

            // ========================================================
            // XỬ LÝ XÓA DÒNG MƯỢT MÀ
            // ========================================================
            $(document).on('click', '.btn-remove-row', function () {
                let vid = $(this).data('id');
                $(`#row_${vid}`).fadeOut(300, function() {
                    $(this).remove();
                    addedVariantIds = addedVariantIds.filter(id => id !== vid);

                    if (addedVariantIds.length === 0) {
                        $('#variantBody').html(`
                            <tr id="emptyRow">
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="fas fa-inbox fs-1 text-secondary opacity-25 mb-3 d-block"></i>
                                    <span class="fw-bold">Chưa có sản phẩm nào được chọn.</span><br />
                                    <small>Vui lòng tìm kiếm sản phẩm ở phía trên và bấm "Tải Biến thể"</small>
                                </td>
                            </tr>
                        `);
                    }
                });
            });

            // Validate form trước khi submit
            $('#promoForm').submit(function (e) {
                if (addedVariantIds.length === 0) {
                    e.preventDefault();
                    alert("Chiến dịch khuyến mãi cần ít nhất 1 cấu hình sản phẩm. Vui lòng thêm dữ liệu!");
                }
            });
        });
    </script>
}