@model IEnumerable<DoAnTotNghiep.Models.Contact>
@{
    ViewData["Title"] = "Quản lý Liên hệ & Tin nhắn";
}
<div class="card shadow-sm mt-4 border-0">
    <div class="card-header bg-primary text-white fw-bold fs-5 py-3">
        📩 QUẢN LÝ TIN NHẮN KHÁCH HÀNG
    </div>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success fw-bold m-3">@TempData["Success"]</div>
    }
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 20%;">Người gửi</th>
                    <th style="width: 40%;">Nội dung tin nhắn</th>
                    <th class="text-center" style="width: 15%;">Ngày gửi</th>
                    <th class="text-center" style="width: 10%;">Trạng thái</th>
                    <th class="text-center" style="width: 10%;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int stt = 1;
                }
                @foreach (var item in Model)
                {
                    <tr class="@(item.Status == 0 ? "table-warning fw-bold" : "")">
                        <td>
                            <div class="text-primary">@item.FullName</div>
                            <small class="text-muted">📞 @item.Phone</small><br />
                            @if (!string.IsNullOrEmpty(item.Email))
                            {
                                <small class="text-muted">✉@item.Email</small>
                            }
                        </td>
                        <td>
                            <div style="white-space: pre-wrap;">@item.Message</div>
                        </td>
                        <td class="text-center text-muted">@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center">
                            @if (item.Status == 0)
                            {
                                <span class="badge bg-danger fs-6">Chưa xử lý</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Đã xử lý</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-1">
                                @if (item.Status == 0)
                                {
                                    <form asp-action="MarkAsRead" asp-route-id="@item.ContactId" method="post" style="display:inline;">
                                        <button type="submit" class="btn btn-sm btn-success" title="Đánh dấu đã xử lý">✔️</button>
                                    </form>
                                }

                                <form asp-action="Delete" asp-route-id="@item.ContactId" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa tin nhắn này không?');" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa tin nhắn">🗑️</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="text-center p-5 text-muted fw-bold">
                Chưa có tin nhắn liên hệ nào từ khách hàng.
            </div>
        }
    </div>
</div>