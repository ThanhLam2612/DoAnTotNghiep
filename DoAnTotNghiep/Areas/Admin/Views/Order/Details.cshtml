@model DoAnTotNghiep.Models.Order
@using Microsoft.EntityFrameworkCore
@inject DoAnTotNghiep.Models.AppDbContext _context
@{
    ViewData["Title"] = "Chi tiết Đơn hàng #" + Model.OrderId;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success fw-bold mt-3">@TempData["Success"]</div>
}

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-dark text-white fw-bold">Thông tin nhận hàng</div>
            <div class="card-body">
                <p><strong>Người nhận:</strong> @Model.CustomerName</p>
                <p><strong>Điện thoại:</strong> @Model.Phone</p>
                <p><strong>Địa chỉ:</strong> @Model.Address</p>

                <p class="mb-2">
                    <strong>Thanh toán:</strong>
                    @if (Model.PaymentMethod == "VNPAY")
                    {
                        <span class="badge bg-primary px-2 py-1 shadow-sm">
                            <i class="fas fa-credit-card me-1"></i> VNPAY
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary px-2 py-1 shadow-sm">
                            <i class="fas fa-truck me-1"></i> COD (Nhận hàng)
                        </span>
                    }
                </p>

                <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                <h4 class="text-danger mt-3">Tổng: @Model.TotalAmount.ToString("#,##0") đ</h4>
            </div>
        </div>

        <div class="card shadow-sm border-warning">
            <div class="card-header bg-warning text-dark fw-bold py-3 fs-5">Cập nhật Trạng thái</div>
            <div class="card-body p-4">
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />

                    @if (Model.Status == 3)
                    {
                        <div class="alert alert-danger text-center fw-bold mb-4">
                            Đơn hàng này đã bị hủy!
                        </div>
                        <select name="status" class="form-select form-select-lg mb-4 fw-bold text-danger" disabled>
                            <option value="3">Đã hủy</option>
                        </select>

                        <button type="button" class="btn btn-secondary btn-lg w-100 fw-bold shadow-sm" disabled>
                            KHÔNG THỂ THAY ĐỔI
                        </button>
                    }
                    else if (Model.Status == 2)
                    {
                        <div class="alert alert-success text-center fw-bold mb-4">
                            Đơn hàng đã giao thành công!
                        </div>
                        <select name="status" class="form-select form-select-lg mb-4 fw-bold text-success" disabled>
                            <option value="2">Hoàn thành</option>
                        </select>

                        <button type="button" class="btn btn-secondary btn-lg w-100 fw-bold shadow-sm" disabled>
                            ĐÃ KẾT THÚC QUY TRÌNH
                        </button>
                    }
                    else
                    {
                        <select name="status" class="form-select form-select-lg mb-4 fw-bold" asp-for="Status">
                            @if (Model.Status == 0)
                            {
                                <option value="0">Chờ duyệt</option>
                                <option value="1">Đang giao hàng</option>
                                <option value="2">Hoàn thành</option>
                                <option value="3">Hủy đơn hàng</option>
                            }
                            else if (Model.Status == 1)
                            {
                                <option value="1">Đang giao hàng</option>
                                <option value="2">Hoàn thành (Khách đã nhận)</option>
                            }
                        </select>

                        <button type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow-sm">
                            LƯU TRẠNG THÁI
                        </button>
                    }
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-info text-dark fw-bold">Sản phẩm đã mua</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tên sản phẩm</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detail in Model.OrderDetails)
                        {
                            var thanhTien = detail.Quantity * detail.Price;

                            // =======================================================
                            // LOGIC TÌM ẢNH ĐÃ ĐƯỢC TỐI ƯU HÓA THEO DB MỚI
                            // =======================================================
                            string finalImageUrl = detail.Product?.ThumbnailUrl;

                            if (detail.ProductVariant != null)
                            {
                                if (!string.IsNullOrEmpty(detail.ProductVariant.ImageUrl))
                                {
                                    finalImageUrl = detail.ProductVariant.ImageUrl; // Lấy ảnh riêng
                                }
                                else
                                {
                                    // Tìm ảnh xài ké (Kiểm tra qua PredefinedAttributeValue)
                                    var colorAttr = detail.ProductVariant.AttributeValues?.FirstOrDefault(a =>
                                    a.PredefinedAttributeValue != null &&
                                    a.PredefinedAttributeValue.ProductAttribute != null &&
                                    (a.PredefinedAttributeValue.ProductAttribute.AttributeName.ToLower().Contains("màu") ||
                                    a.PredefinedAttributeValue.ProductAttribute.AttributeName.ToLower().Contains("color")));

                                    if (colorAttr != null)
                                    {
                                        // CHỈ CẦN SO SÁNH ID - NHANH HƠN CHUỖI GẤP NHIỀU LẦN
                                        int predefinedColorId = colorAttr.PredefinedValueId;

                                        var siblingVariant = _context.ProductVariants
                                        .Include(v => v.AttributeValues)
                                        .FirstOrDefault(v => v.ProductId == detail.ProductId
                                        && v.VariantId != detail.VariantId
                                        && !string.IsNullOrEmpty(v.ImageUrl)
                                        && v.AttributeValues.Any(a => a.PredefinedValueId == predefinedColorId));

                                        if (siblingVariant != null)
                                        {
                                            finalImageUrl = siblingVariant.ImageUrl;
                                        }
                                    }
                                }
                            }
                            // =======================================================

                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(finalImageUrl))
                                        {
                                            <img src="@finalImageUrl" style="width:40px; height:40px; object-fit:cover" class="me-3 border rounded shadow-sm" />
                                        }

                                        <div>
                                            <div class="fw-bold">@detail.Product?.ProductName</div>

                                            @if (detail.ProductVariant != null && detail.ProductVariant.AttributeValues != null)
                                            {
                                                <div class="small text-muted mt-1 d-flex flex-wrap align-items-center gap-1">
                                                    @{
                                                        var attrList = detail.ProductVariant.AttributeValues.ToList();
                                                        for (int i = 0; i < attrList.Count; i++)
                                                        {
                                                            var av = attrList[i];
                                                            var preDef = av.PredefinedAttributeValue;

                                                            if (preDef != null && preDef.ProductAttribute != null)
                                                            {
                                                                bool isColor = preDef.ProductAttribute.AttributeName.ToLower().Contains("màu") ||
                                                                preDef.ProductAttribute.AttributeName.ToLower().Contains("color");

                                                                <span class="d-inline-flex align-items-center">
                                                                    @if (isColor && !string.IsNullOrEmpty(preDef.ColorHex))
                                                                    {
                                                                        @preDef.ProductAttribute.AttributeName
                                                                        <span>:</span>
                                                                        <span class="rounded-circle border border-secondary mx-1 shadow-sm"
                                                                              style="width: 12px; height: 12px; background-color: @preDef.ColorHex; display: inline-block;">
                                                                        </span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span>@preDef.ProductAttribute.AttributeName: @preDef.Value</span>
                                                                    }
                                                                </span>

                                                                if (i < attrList.Count - 1)
                                                                {
                                                                    <span class="mx-1">|</span>
                                                                }
                                                            }
                                                        }
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">x @detail.Quantity</td>
                                <td class="text-end">@detail.Price.ToString("#,##0") đ</td>
                                <td class="text-end fw-bold text-danger">@thanhTien.ToString("#,##0") đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <a asp-action="Index" class="btn btn-secondary mt-3">Quay lại danh sách</a>
    </div>
</div>