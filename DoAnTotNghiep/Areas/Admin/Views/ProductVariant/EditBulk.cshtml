@model List<DoAnTotNghiep.Models.ProductVariant>
@{
    var product = ViewBag.Product as DoAnTotNghiep.Models.Product;
    ViewData["Title"] = "Sửa cấu hình hàng loạt";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mb-5">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Sửa hàng loạt: <span class="text-primary fw-bold">@product.ProductName</span></h1>
        <a asp-action="Index" asp-route-productId="@product.ProductId" class="btn btn-sm btn-secondary shadow-sm">
            <i class="fas fa-arrow-left fa-sm text-white-50"></i> Quay lại danh sách
        </a>
    </div>

    <form asp-action="EditBulk" method="post" enctype="multipart/form-data" id="bulkEditForm">
        <input type="hidden" name="productId" value="@product.ProductId" />

        <div class="card shadow mb-4 border-left-warning">
            <div class="card-header py-3 bg-warning text-dark d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold"><i class="fas fa-edit me-2"></i> BẢNG CHỈNH SỬA NHANH</h6>
                <span class="badge bg-white text-dark shadow-sm">@Model.Count() biến thể</span>
            </div>
            <div class="card-body p-0">
                @{
                    var groupedVariants = Model.GroupBy(v =>
                    {
                        var colorAttr = v.AttributeValues?.FirstOrDefault(a => a.PredefinedAttributeValue?.ProductAttribute?.AttributeName.ToLower().Contains("màu") == true);
                        return colorAttr != null ? colorAttr.PredefinedValueId : 0;
                    }).ToList();

                    var colorImageMap = new Dictionary<int, string>();
                    foreach (var variant in Model)
                    {
                        if (!string.IsNullOrEmpty(variant.ImageUrl))
                        {
                            var colorAttr = variant.AttributeValues?.FirstOrDefault(a => a.PredefinedAttributeValue?.ProductAttribute?.AttributeName.ToLower().Contains("màu") == true);
                            if (colorAttr != null && !colorImageMap.ContainsKey(colorAttr.PredefinedValueId))
                            {
                                colorImageMap[colorAttr.PredefinedValueId] = variant.ImageUrl;
                            }
                        }
                    }
                }

                <div class="table-responsive">
                    <table class="table table-hover table-bordered align-middle mb-0">
                        <thead class="table-light text-center">
                            <tr>
                                <th width="200">Ảnh đại diện Nhóm</th>
                                <th>Thông số cấu hình</th>
                                <th width="200">Giá bán (VNĐ)</th>
                                <th width="150">Tồn kho</th>
                                <th width="100">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int absoluteIndex = 0;
                            }
                            @foreach (var group in groupedVariants)
                            {
                                int rowCount = group.Count();
                                int currentColorId = group.Key;

                                string groupColorName = "Bản tiêu chuẩn";
                                if (currentColorId != 0)
                                {
                                    groupColorName = group.First().AttributeValues.First(a => a.PredefinedValueId == currentColorId).PredefinedAttributeValue.Value;
                                }
                                string groupImageUrl = colorImageMap.ContainsKey(currentColorId) ? colorImageMap[currentColorId] : "";
                                string groupIndexes = string.Join(",", Enumerable.Range(absoluteIndex, rowCount));

                                int localIndex = 0;
                                foreach (var item in group)
                                {
                                    <tr id="row_@item.VariantId">
                                        <input type="hidden" name="updates[@absoluteIndex].VariantId" value="@item.VariantId" />
                                        <td class="d-none"><input type="file" name="updates[@absoluteIndex].ImageFile" id="hidden_img_@absoluteIndex" /></td>

                                        @if (localIndex == 0)
                                        {
                                            <td rowspan="@rowCount" class="align-middle text-center bg-light border-end">
                                                <span class="badge bg-primary mb-2 px-3 py-2 fs-6 shadow-sm">@groupColorName</span><br />
                                                @if (!string.IsNullOrEmpty(groupImageUrl))
                                                {
                                                    <img src="@groupImageUrl" style="width: 50px; height: 50px; object-fit: contain;" class="border rounded bg-white p-1 mb-2" />
                                    
                                                    <br />
                                                }
                                                <div class="small text-muted mb-1">Tải ảnh mới để thay thế:</div>
                                                <input type="file" class="form-control form-control-sm group-image-upload shadow-sm" data-indexes="@groupIndexes" accept="image/*" />
                                            </td>
                                        }

                                        <td class="fw-bold text-dark px-4">
                                            @foreach (var attr in item.AttributeValues.Where(a => a.PredefinedValueId != currentColorId))
                                            {
                                                <span class="me-2 text-primary">@attr.PredefinedAttributeValue.Value</span>
                                            }
                                        </td>
                                        <td class="px-3">
                                            <div class="input-group input-group-sm">
                                                <input type="number" name="updates[@absoluteIndex].Price" class="form-control text-end fw-bold text-danger" value="@Math.Round(item.Price, 0)" min="0" required />
                                                <span class="input-group-text bg-white">đ</span>
                                            </div>
                                        </td>
                                        <td class="px-3">
                                            <input type="number" name="updates[@absoluteIndex].StockQuantity" class="form-control text-center" value="@item.StockQuantity" min="0" required />
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-outline-danger shadow-sm rounded-circle" onclick="deleteVariant(@item.VariantId)" title="Xóa dòng này">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    localIndex++;
                                    absoluteIndex++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="p-4 bg-light text-end border-top">
                    <button type="submit" class="btn btn-warning btn-lg px-5 shadow fw-bold text-dark">
                        <i class="fas fa-save me-2"></i> LƯU THAY ĐỔI
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Chép file từ ảnh nhóm xuống các input ẩn để gửi về C#
            $(document).on('change', '.group-image-upload', function() {
                let indexes = $(this).data('indexes').toString().split(',');
                let files = this.files;
                indexes.forEach(idx => {
                    let hiddenInput = document.getElementById('hidden_img_' + idx);
                    if(hiddenInput) {
                        let dt = new DataTransfer();
                        if(files.length > 0) dt.items.add(files[0]);
                        hiddenInput.files = dt.files;
                    }
                });
            });
        });

        // Hàm xóa nhanh bằng AJAX
        function deleteVariant(variantId) {
            if (confirm("Bạn có chắc chắn muốn xóa cấu hình này? (Hành động này sẽ xóa ngay lập tức khỏi CSDL)")) {
                fetch('@Url.Action("DeleteAjax", "ProductVariant", new { area = "Admin" })', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `variantId=${variantId}`
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        $(`#row_${variantId}`).fadeOut(400, function() { $(this).remove(); });
                    } else {
                        alert(data.message);
                    }
                });
            }
        }
    </script>
}