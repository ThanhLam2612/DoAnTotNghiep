
@model DoAnTotNghiep.Models.ProductVariant

@{
    ViewData["Title"] = "Sửa Biến thể";
}

<div class="card shadow-sm mt-4">
    <div class="card-header bg-warning text-dark">
        <h4 class="mb-0">Sửa Phiên bản của: @ViewBag.ProductName</h4>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="VariantId" />
            <input type="hidden" asp-for="ProductId" />

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label class="control-label fw-bold">Mã phân loại hàng (SKU)</label>
                        <input asp-for="SKU" class="form-control" />
                        <span asp-validation-for="SKU" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label fw-bold">Giá bán cộng thêm (VNĐ)</label>
                        <input asp-for="AdditionalPrice" class="form-control" type="number" />
                        <span asp-validation-for="AdditionalPrice" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label fw-bold">Số lượng tồn kho</label>
                        <input asp-for="StockQuantity" class="form-control" type="number" />
                        <span asp-validation-for="StockQuantity" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-success mt-3">Lưu thay đổi</button>
                    <a asp-action="Index" asp-route-productId="@Model.ProductId" class="btn btn-secondary mt-3 ms-2">Hủy bỏ</a>
                </div>
            </div>
        </form>
    </div>
</div>