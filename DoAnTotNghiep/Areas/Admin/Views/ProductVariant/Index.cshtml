@{
}
@model IEnumerable<DoAnTotNghiep.Models.ProductVariant>

@{
    ViewData["Title"] = "Quản lý Biến thể";
}

<div class="card mt-4 shadow-sm">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Các phiên bản của: @ViewBag.ProductName</h4>
    </div>
    <div class="card-body">
        <p>
            <a asp-action="Create" asp-route-productId="@ViewBag.ProductId" class="btn btn-success">
                + Thêm phiên bản mới (SKU)
            </a>

            <a asp-controller="Product" asp-action="Index" class="btn btn-secondary ms-2">
                Quay lại danh sách Sản phẩm gốc
            </a>
        </p>

        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Mã hàng (SKU)</th>
                    <th>Giá cộng thêm (+)</th>
                    <th>Giá cuối cùng</th>
                    <th>Tồn kho</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-primary">@item.SKU</td>
                        <td class="text-danger">+ @item.AdditionalPrice.ToString("#,##0") đ</td>

                        <td><i class="text-muted">(Sẽ tính gộp với giá gốc khi hiển thị web)</i></td>

                        <td>
                            <span class="badge @(item.StockQuantity > 0 ? "bg-success" : "bg-danger")">
                                @item.StockQuantity sản phẩm
                            </span>
                        </td>
                        <td>
                            <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.VariantId">Sửa</a>
                            <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.VariantId">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>