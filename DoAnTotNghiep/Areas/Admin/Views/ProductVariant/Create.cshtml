@model DoAnTotNghiep.Models.ProductVariant

@{
    ViewData["Title"] = "Thêm Phiên bản";
}

<div class="card shadow-sm mt-4">
    <div class="card-header bg-success text-white">
        <h4 class="mb-0">Thêm Phiên bản cho: @ViewBag.ProductName</h4>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" name="ProductId" value="@ViewBag.ProductId" />

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label class="control-label fw-bold">Mã phân loại hàng (SKU)</label>
                        <input asp-for="SKU" class="form-control" placeholder="VD: IP15-RED-128GB" />
                        <span asp-validation-for="SKU" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label fw-bold">Giá bán cộng thêm (VNĐ)</label>
                        <small class="d-block text-muted">Giá bán thực tế = Giá gốc sản phẩm + Giá này</small>
                        <input asp-for="AdditionalPrice" class="form-control" type="number" value="0" />
                        <span asp-validation-for="AdditionalPrice" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label fw-bold">Số lượng tồn kho</label>
                        <input asp-for="StockQuantity" class="form-control" type="number" value="10" />
                        <span asp-validation-for="StockQuantity" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary mt-3">Lưu Phiên bản</button>
                    <a asp-action="Index" asp-route-productId="@ViewBag.ProductId" class="btn btn-secondary mt-3 ms-2">Hủy bỏ</a>
                </div>
            </div>
        </form>
    </div>
</div>