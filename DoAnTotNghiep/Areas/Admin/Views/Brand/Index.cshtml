@{
}
@model IEnumerable<DoAnTotNghiep.Models.Brand>

@{
    ViewData["Title"] = "Danh sách Thương hiệu";
}

<div class="container mt-4">
    <h2>Quản lý Thương hiệu</h2>
    <p><a asp-action="Create" class="btn btn-primary">Thêm mới</a></p>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Logo</th>
                <th>Tên thương hiệu</th>
                <th>Tạo bởi</th>
                <th>Sửa lần cuối</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="width: 150px">
                        @if (!string.IsNullOrEmpty(item.LogoUrl))
                        {
                            <img src="@item.LogoUrl" style="width: 100px; height: auto;" />
                        }
                        else
                        {
                            <span>Chưa có ảnh</span>
                        }
                    </td>
                    <td>@item.BrandName</td>
                    <td>
                        <span class="d-block text-muted small">@item.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</span>
                        <span class="badge bg-success">@item.CreatedBy</span>
                    </td>

                    <td>
                        @if (item.UpdatedDate.HasValue)
                        {
                            <span class="d-block text-muted small">@item.UpdatedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            <span class="badge bg-warning text-dark">@item.UpdatedBy</span>
                        }
                        else
                        {
                            <span class="text-muted small fst-italic">Chưa chỉnh sửa</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.BrandId" class="btn btn-warning btn-sm">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.BrandId" class="btn btn-danger btn-sm">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>