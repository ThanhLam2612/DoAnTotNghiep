@{
}
@model DoAnTotNghiep.Models.Brand

@{
    ViewData["Title"] = "Xác nhận Xóa";
}

<div class="card shadow-sm mt-4 border-danger">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0">CẢNH BÁO XÓA DỮ LIỆU</h4>
    </div>
    <div class="card-body">
        <h5 class="card-title">Bạn có chắc chắn muốn xóa thương hiệu này không?</h5>
        <p class="text-danger">Lưu ý: File ảnh logo cũng sẽ bị xóa vĩnh viễn khỏi hệ thống.</p>
        <hr />

        <div class="row">
            <div class="col-md-3 text-center">
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <img src="@Model.LogoUrl" class="img-thumbnail" style="max-width: 150px;" />
                }
            </div>
            <div class="col-md-9">
                <dl class="row">
                    <dt class="col-sm-4">Mã thương hiệu:</dt>
                    <dd class="col-sm-8">@Model.BrandId</dd>

                    <dt class="col-sm-4">Tên thương hiệu:</dt>
                    <dd class="col-sm-8 fw-bold text-primary">@Model.BrandName</dd>
                </dl>

                <form asp-area="Admin" asp-controller="Brand" asp-action="Delete" method="post">
                    <input type="hidden" asp-for="BrandId" />
                    <button type="submit" class="btn btn-danger">Đồng ý Xóa</button>
                    <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
                </form>
            </div>
        </div>
    </div>
</div>