@{
}
@model DoAnTotNghiep.Models.Brand

@{
    ViewData["Title"] = "Sửa Thương hiệu";
}

<div class="card shadow-sm mt-4">
    <div class="card-header bg-warning text-dark">
        <h4 class="mb-0">Sửa Thương hiệu</h4>
    </div>
    <div class="card-body">
        <form asp-area="Admin" asp-controller="Brand" asp-action="Edit" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="BrandId" />
            <input type="hidden" asp-for="LogoUrl" />

            <div class="row">
                <div class="col-md-8">
                    <div class="form-group mb-3">
                        <label asp-for="BrandName" class="control-label fw-bold">Tên thương hiệu</label>
                        <input asp-for="BrandName" class="form-control" />
                        <span asp-validation-for="BrandName" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label fw-bold">Cập nhật Logo mới</label>
                        <input type="file" name="logoImage" class="form-control" accept="image/*" />
                    </div>

                    <div class="form-group mt-4">
                        <button type="submit" class="btn btn-success">Lưu thay đổi</button>
                        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                    </div>
                </div>

                <div class="col-md-4 text-center">
                    <label class="fw-bold mb-2">Logo hiện tại</label>
                    <div class="border p-2">
                        @if (!string.IsNullOrEmpty(Model.LogoUrl))
                        {
                            <img src="@Model.LogoUrl" style="max-width: 100%; height: auto; max-height: 150px;" alt="Logo" />
                        }
                        else
                        {
                            <span class="text-muted">Chưa có ảnh</span>
                        }
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>