
@model IEnumerable<DoAnTotNghiep.Models.Product>

@{
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<div class="container mt-4">
    <h2>Danh sách Sản phẩm</h2>
    <p><a asp-action="Create" class="btn btn-primary">Thêm mới</a></p>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Giá</th>
                <th>Danh mục</th>
                <th>Thương hiệu</th>
                <th>Tạo bởi</th>
                <th>Sửa lần cuối</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td style="width: 100px">
                        @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                        {
                            <img src="@item.ThumbnailUrl" style="width: 80px; height: auto;" />
                        }
                    </td>
                    <td>@item.ProductName</td>
                    <td>@item.BasePrice.ToString("#,##0") VNĐ</td>

                    <td>@item.Category?.CategoryName</td>

                    <td>@item.Brand?.BrandName</td>
                    <td>
                        <span class="d-block text-muted small">@item.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</span>
                        <span class="badge bg-success">@item.CreatedBy</span>
                    </td>

                    <td>
                        @if (item.UpdatedDate.HasValue)
                        {
                            <span class="d-block text-muted small">@item.UpdatedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            <span class="badge bg-warning text-dark">@item.UpdatedBy</span>
                        }
                        else
                        {
                            <span class="text-muted small fst-italic">Chưa chỉnh sửa</span>
                        }
                    </td>
                    <td>
                        @* <a asp-controller="ProductVariant" asp-action="Index" asp-route-productId="@item.ProductId" class="btn btn-info btn-sm">Biến thể</a> *@
                        <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-warning btn-sm">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-danger btn-sm">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>