@model IEnumerable<DoAnTotNghiep.Models.Product>

@{
    ViewData["Title"] = "Quản lý Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">📱 Danh sách Sản phẩm</h2>
        <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm rounded-pill px-4">
            ➕ Thêm sản phẩm
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4 bg-light">
        <div class="card-body p-3">
            <form asp-action="Index" method="get">
                <div class="row g-2 align-items-end">

                    <div class="col-md-4">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">🔍 Tìm kiếm</label>
                        <input type="text" name="searchString" class="form-control border-secondary" value="@ViewBag.SearchString" placeholder="Nhập tên sản phẩm...">
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">Danh mục</label>
                        <select name="categoryId" class="form-select border-secondary" asp-items="ViewBag.CategoryId">
                            <option value="">-- Tất cả Danh mục --</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">Thương hiệu</label>
                        <select name="brandId" class="form-select border-secondary" asp-items="ViewBag.BrandId">
                            <option value="">-- Tất cả Thương hiệu --</option>
                        </select>
                    </div>

                    <div class="col-md-2 d-flex gap-2">
                        <button type="submit" class="btn btn-primary fw-bold flex-grow-1 shadow-sm">Lọc</button>

                        @if (!string.IsNullOrEmpty(ViewBag.SearchString) ||
                                                (ViewData["CategoryId"] as SelectList)?.SelectedValue != null ||
                                                (ViewData["BrandId"] as SelectList)?.SelectedValue != null)
                        {
                            <a asp-action="Index" class="btn btn-outline-danger fw-bold px-3 shadow-sm" title="Xóa bộ lọc">❌</a>
                        }
                    </div>

                </div>
            </form>
        </div>
    </div>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="py-3 px-3 text-center" style="width: 10%;">Ảnh</th>
                            <th class="py-3" style="width: 20%;">Tên Sản phẩm</th>
                            <th class="py-3" style="width: 15%;">Phân loại</th>
                            <th class="py-3" style="width: 10%;">Giá</th>
                            <th class="py-3 text-center" style="width: 15%;">Tạo bởi</th>
                            <th class="py-3 text-center" style="width: 15%;">Sửa lần cuối</th>
                            <th class="py-3 text-center" style="width: 15%;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center py-2 px-3">
                                        @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                                        {
                                            <img src="@item.ThumbnailUrl" alt="@item.ProductName" class="img-fluid rounded shadow-sm bg-white p-1" style="height: 60px; width: 60px; object-fit: contain;" />
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Chưa có ảnh</span>
                                        }
                                    </td>

                                    <td class="fw-bold text-dark">
                                        <div style="max-height: 45px; overflow: hidden; text-overflow: ellipsis;">
                                            @item.ProductName
                                        </div>
                                    </td>

                                    <td>
                                        <span class="badge bg-info text-dark shadow-sm d-block mb-1">📁 @item.Category?.CategoryName</span>
                                        <span class="badge bg-secondary shadow-sm d-block">🏷️ @item.Brand?.BrandName</span>
                                    </td>

                                    <td class="fw-bold text-danger">
                                        @item.BasePrice.ToString("#,##0") VNĐ
                                    </td>

                                    <td class="text-center">
                                        <span class="d-block text-muted small">@item.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</span>
                                        <span class="badge bg-success">@item.CreatedBy</span>
                                    </td>

                                    <td class="text-center">
                                        @if (item.UpdatedDate.HasValue)
                                        {
                                            <span class="d-block text-muted small">@item.UpdatedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                            <span class="badge bg-warning text-dark">@item.UpdatedBy</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small fst-italic">Chưa chỉnh sửa</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            @* <a asp-controller="ProductVariant" asp-action="Index" asp-route-productId="@item.ProductId" class="btn btn-sm btn-outline-info" title="Biến thể">📦</a> *@
                                            <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-primary" title="Sửa">✏️</a>
                                            <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-danger" title="Xóa">🗑️</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted fw-bold fs-5">
                                    📭 Chưa có sản phẩm nào phù hợp!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@if (ViewBag.TotalPages > 1)
{
    int? filterCategory = (ViewData["CategoryId"] as SelectList)?.SelectedValue as int?;
    int? filterBrand = (ViewData["BrandId"] as SelectList)?.SelectedValue as int?;

    <nav aria-label="Page navigation" class="mt-4 mb-5">
        <ul class="pagination justify-content-center shadow-sm">

            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link fw-bold" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-searchString="@ViewBag.SearchString"
                   asp-route-categoryId="@filterCategory"
                   asp-route-brandId="@filterBrand">❮ Trước</a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link fw-bold" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-searchString="@ViewBag.SearchString"
                       asp-route-categoryId="@filterCategory"
                       asp-route-brandId="@filterBrand">@i</a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link fw-bold" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-searchString="@ViewBag.SearchString"
                   asp-route-categoryId="@filterCategory"
                   asp-route-brandId="@filterBrand">Sau ❯</a>
            </li>

        </ul>
    </nav>
}

<style>