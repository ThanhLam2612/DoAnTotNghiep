@{
}
@model DoAnTotNghiep.Models.Category

@{
    ViewData["Title"] = "Xác nhận Xóa";
}

<div class="card shadow-sm mt-4 border-danger">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0">CẢNH BÁO XÓA DỮ LIỆU</h4>
    </div>
    <div class="card-body">
        <h5 class="card-title">Bạn có chắc chắn muốn xóa danh mục này không?</h5>
        <hr />
        <dl class="row">
            <dt class="col-sm-3">Mã danh mục:</dt>
            <dd class="col-sm-9">@Model.CategoryId</dd>

            <dt class="col-sm-3">Tên danh mục:</dt>
            <dd class="col-sm-9 text-danger fw-bold">@Model.CategoryName</dd>
        </dl>

        <form asp-area="Admin" asp-controller="Category" asp-action="Delete" method="post">
            <input type="hidden" asp-for="CategoryId" />
            <button type="submit" class="btn btn-danger">Đồng ý Xóa</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
        </form>
    </div>
</div>