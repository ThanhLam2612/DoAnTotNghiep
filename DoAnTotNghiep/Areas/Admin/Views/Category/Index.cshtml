@model IEnumerable<DoAnTotNghiep.Models.Category>

@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="container mt-4 mb-5">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm fw-bold" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm fw-bold" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">Danh sách Danh mục sản phẩm</h2>
        <a asp-action="Create" asp-controller="Category" asp-area="Admin" class="btn btn-primary fw-bold shadow-sm rounded-pill px-4">
            <i class="fa-solid fa-plus"></i> Tạo mới
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4 bg-light">
        <div class="card-body p-3">
            <form asp-action="Index" method="get">
                <div class="row">
                    <div class="col-md-6 col-lg-5">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-2">Tìm kiếm danh mục</label>

                        <div class="input-group shadow-sm">
                            <input type="text" name="searchString" class="form-control border-secondary" value="@ViewBag.SearchString" placeholder="Nhập tên danh mục...">

                            <button type="submit" class="btn btn-primary fw-bold px-4">
                                Tìm kiếm
                            </button>

                            @if (!string.IsNullOrEmpty(ViewBag.SearchString))
                            {
                                <a asp-action="Index" class="btn btn-outline-danger fw-bold px-3" title="Xóa tìm kiếm">
                                    <i class="fa-solid fa-xmark"></i>
                                </a>
                            }
                        </div>

                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="py-3 px-4">Tên danh mục</th>
                            <th class="py-3">Tạo bởi</th>
                            <th class="py-3">Sửa lần cuối</th>
                            <th class="py-3 text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 fw-bold">
                                    @Html.DisplayFor(modelItem => item.CategoryName)
                                </td>
                                <td>
                                    <span class="d-block text-muted small">@item.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</span>
                                    <span class="badge bg-success">@item.CreatedBy</span>
                                </td>
                                <td>
                                    @if (item.UpdatedDate.HasValue)
                                    {
                                        <span class="d-block text-muted small">@item.UpdatedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                        <span class="badge bg-warning text-dark">@item.UpdatedBy</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small fst-italic">Chưa chỉnh sửa</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-warning fw-bold"><i class="fas fa-edit"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-danger fw-bold"><i class="fas fa-trash-alt"></i></a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4 mb-5">
        <ul class="pagination justify-content-center shadow-sm">

            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link fw-bold" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-searchString="@ViewBag.SearchString">
                    ❮ Trước
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link fw-bold" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-searchString="@ViewBag.SearchString">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link fw-bold" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-searchString="@ViewBag.SearchString">
                    Sau ❯
                </a>
            </li>

        </ul>
    </nav>
}