@{
}
@model IEnumerable<DoAnTotNghiep.Models.Category>

@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="container mt-4">
    <h2>Danh sách Danh mục sản phẩm</h2>

    <p>
        
        <a asp-action="Create" asp-controller="Category" asp-area="Admin" class="btn btn-primary">Tạo mới</a>
    </p>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Tên danh mục</th>
                <th>Tạo bởi</th>
                <th>Sửa lần cuối</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.CategoryName)
                    </td>
                    <td>
                        <span class="d-block text-muted small">@item.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</span>
                        <span class="badge bg-success">@item.CreatedBy</span>
                    </td>

                    <td>
                        @if (item.UpdatedDate.HasValue)
                        {
                            <span class="d-block text-muted small">@item.UpdatedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            <span class="badge bg-warning text-dark">@item.UpdatedBy</span>
                        }
                        else
                        {
                            <span class="text-muted small fst-italic">Chưa chỉnh sửa</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-warning">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>