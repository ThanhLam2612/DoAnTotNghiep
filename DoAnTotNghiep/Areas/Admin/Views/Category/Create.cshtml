@{
}
@model DoAnTotNghiep.Models.Category

@{
    ViewData["Title"] = "Tạo mới Danh mục";
}

<div class="container mt-4">
    <h2>Tạo mới Danh mục</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <div asp-validation-summary="All" class="text-danger"></div>
            <form asp-area="Admin" asp-controller="Category" asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="CategoryName" class="control-label fw-bold">Tên danh mục</label>
                    <input asp-for="CategoryName" class="form-control" placeholder="Ví dụ: Điện thoại, Laptop..." />
                    <span asp-validation-for="CategoryName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <input type="submit" value="Tạo mới" class="btn btn-success" />
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}