@model IEnumerable<DoAnTotNghiep.Models.AppUser>

@{
    ViewData["Title"] = "Quản lý Nhân sự";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4 mb-5">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show fw-bold shadow-sm" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show fw-bold shadow-sm" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">👨‍💼 Danh sách Nhân sự</h2>
        <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm rounded-pill px-4">
            ➕ Thêm nhân sự mới
        </a>
    </div>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="py-3 px-4 text-center" style="width: 5%;">STT</th>
                            <th class="py-3" style="width: 20%;">Họ và Tên</th>
                            <th class="py-3" style="width: 15%;">Tài khoản</th>
                            <th class="py-3" style="width: 15%;">Số điện thoại</th>
                            <th class="py-3" style="width: 20%;">Email</th>
                            <th class="py-3 text-center" style="width: 10%;">Phân quyền</th>
                            <th class="py-3 text-center" style="width: 10%;">Trạng thái</th>
                            <th class="py-3 text-center" style="width: 10%;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int stt = 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center px-4 fw-bold text-muted">@(stt++)</td>
                                    <td class="fw-bold text-dark">@item.FullName</td>
                                    <td><span class="text-secondary">@item.Username</span></td>
                                    <td class="fw-bold">@item.Phone</td>
                                    <td>@item.Email</td>

                                    <td class="text-center">
                                        @if (item.Role == "Admin")
                                        {
                                            <span class="badge bg-danger rounded-pill px-3 py-2 shadow-sm">
                                                👑 Admin
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info text-dark rounded-pill px-3 py-2 shadow-sm">
                                                💼 Nhân viên
                                            </span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success rounded-pill shadow-sm"><i class="bi bi-check-circle"></i> Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill shadow-sm"><i class="bi bi-lock-fill"></i> Đã khóa</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                                ✏️
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.UserId"
                                               class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                               onclick="return confirm('Bạn có chắc chắn muốn @(item.IsActive ? "KHÓA" : "MỞ KHÓA") tài khoản của [@item.FullName] không?');"
                                               title="@(item.IsActive ? "Khóa tài khoản" : "Mở khóa tài khoản")">
                                                @(item.IsActive ? "🔒" : "🔓")
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted fw-bold fs-5">
                                    📭 Chưa có dữ liệu nhân sự nào trong hệ thống!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    /* CSS làm mượt bảng */
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: background-color 0.2s ease-in-out;
    }
</style>