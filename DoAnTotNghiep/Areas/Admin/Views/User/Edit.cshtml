@model DoAnTotNghiep.Models.AppUser

@{
    ViewData["Title"] = "Chỉnh sửa Nhân sự";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">✏️ Chỉnh sửa thông tin</h2>
        @if (Model.Role == "Admin" || Model.Role == "Employee")
        {
            <a asp-action="StaffIndex" class="btn btn-outline-secondary fw-bold shadow-sm rounded-pill px-4">
                ⬅ Quay lại
            </a>
        }
        else
        {
            <a asp-action="CustomerIndex" class="btn btn-outline-secondary fw-bold shadow-sm rounded-pill px-4">
                ⬅ Quay lại
            </a>
        }
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
            <h5 class="fw-bold text-muted">Cập nhật hồ sơ tài khoản</h5>
        </div>
        <div class="card-body p-4">

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="UserId" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                <div class="row g-4">
                    <div class="col-md-6 border-end pe-4">
                        <h6 class="text-primary fw-bold mb-3"><i class="bi bi-person-lines-fill"></i> Thông tin cá nhân</h6>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-bold">Họ và Tên <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" readonly/>
                            
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" class="form-control" type="email" readonly/>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                            <input asp-for="Phone" class="form-control" readonly/>
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DateOfBirth" class="form-label fw-bold">Ngày sinh</label>
                            <input asp-for="DateOfBirth" class="form-control" type="date" readonly/>
                        </div>
                    </div>

                    <div class="col-md-6 ps-4">
                        <h6 class="text-danger fw-bold mb-3"><i class="bi bi-shield-lock-fill"></i> Phân quyền & Bảo mật</h6>

                        <div class="mb-3">
                            <label asp-for="Username" class="form-label fw-bold">Tên đăng nhập <span class="text-muted">(Không được sửa)</span></label>
                            <input asp-for="Username" class="form-control bg-light text-muted" readonly />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Role" class="form-label fw-bold">Phân quyền (Chức vụ) <span class="text-danger">*</span></label>
                            <select asp-for="Role" class="form-select border-primary">
                                <option value="Employee">💼 Nhân viên (Quyền hạn giới hạn)</option>
                                <option value="Admin">👑 Quản trị viên (Toàn quyền)</option>
                            </select>
                        </div>
                    </div>
                </div>

                <hr class="my-4 text-muted">

                <div class="text-end">
                    <button type="submit" class="btn btn-primary btn-lg fw-bold px-5 shadow-sm">
                        💾 CẬP NHẬT THÔNG TIN
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}