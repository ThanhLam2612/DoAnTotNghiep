@model DoAnTotNghiep.Models.AppUser

@{
    ViewData["Title"] = "Thêm Tài khoản mới";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">Thêm Tài khoản mới</h2>
        <a asp-action="Index" class="btn btn-outline-secondary fw-bold shadow-sm rounded-pill px-4">
            Quay lại danh sách
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
            <h5 class="fw-bold text-muted">Vui lòng điền đầy đủ thông tin bên dưới</h5>
        </div>
        <div class="card-body p-4">

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                <div class="row g-4">
                    <div class="col-md-6 border-end pe-4">
                        <h6 class="text-primary fw-bold mb-3"><i class="bi bi-person-lines-fill"></i> Thông tin cá nhân</h6>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-bold">Họ và Tên <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control" placeholder="" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                            <input asp-for="Phone" class="form-control" placeholder="" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DateOfBirth" class="form-label fw-bold">Ngày sinh</label>
                            <input asp-for="DateOfBirth" class="form-control" type="date" />
                        </div>
                    </div>

                    <div class="col-md-6 ps-4">
                        <h6 class="text-danger fw-bold mb-3"><i class="bi bi-shield-lock-fill"></i> Thông tin Tài khoản</h6>

                        <div class="mb-3">
                            <label asp-for="Username" class="form-label fw-bold">Tên đăng nhập <span class="text-danger">*</span></label>
                            <input asp-for="Username" class="form-control" placeholder="" />
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Role" class="form-label fw-bold">Phân quyền <span class="text-danger">*</span></label>
                            <select asp-for="Role" class="form-select bg-light">
                                <option value="Customer">Khách hàng</option>
                                <option value="Employee">Nhân viên</option>
                                <option value="Admin">Quản trị viên</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-bold">Mật khẩu <span class="text-danger">*</span></label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold">Xác nhận Mật khẩu <span class="text-danger">*</span></label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <hr class="my-4 text-muted">

                <div class="text-end">
                    <button type="submit" class="btn btn-primary btn-lg fw-bold px-5 shadow-sm">
                        LƯU TÀI KHOẢN
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}