@model IEnumerable<DoAnTotNghiep.Models.AppUser>

@{
    ViewData["Title"] = "Quản lý Người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4 mb-5">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show fw-bold shadow-sm" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show fw-bold shadow-sm" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">Danh sách Người dùng</h2>
        <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm rounded-pill px-4">
            Thêm tài khoản mới
        </a>
    </div>
    <div class="card shadow-sm border-0 rounded-4 mb-4 bg-light">
        <div class="card-body p-3">
            <form asp-action="Index" method="get">
                <div class="row g-2 align-items-end">

                    <div class="col-md-4">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">Tìm kiếm</label>
                        <input type="text" name="searchString" class="form-control border-secondary" value="@ViewBag.SearchString" placeholder="Tên, username, SĐT, Email...">
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">Phân quyền</label>
                        <select name="role" class="form-select border-secondary">
                            <option value="">-- Tất cả --</option>
                            <option value="Admin" selected="@((string)ViewBag.Role == "Admin")">Admin</option>
                            <option value="Employee" selected="@((string)ViewBag.Role == "Employee")">Nhân viên</option>
                            <option value="Customer" selected="@((string)ViewBag.Role == "Customer")">Khách hàng</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">Trạng thái</label>
                        <select name="isActive" class="form-select border-secondary">
                            <option value="">-- Tất cả --</option>
                            <option value="true" selected="@((bool?)ViewBag.IsActive == true)">Đang hoạt động</option>
                            <option value="false" selected="@((bool?)ViewBag.IsActive == false)">Đã khóa</option>
                        </select>
                    </div>

                    <div class="col-md-2 d-flex gap-2">
                        <button type="submit" class="btn btn-primary fw-bold flex-grow-1 shadow-sm">Lọc</button>
                        <a asp-action="Index" class="btn btn-outline-danger fw-bold px-3 shadow-sm" title="Xóa bộ lọc"><i class="fa-solid fa-xmark"></i></a>
                    </div>

                </div>
            </form>
        </div>
    </div>
    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="py-3" style="width: 20%;">Họ và Tên</th>
                            <th class="py-3" style="width: 15%;">Tài khoản</th>
                            <th class="py-3" style="width: 15%;">Số điện thoại</th>
                            <th class="py-3" style="width: 20%;">Email</th>
                            <th class="py-3 text-center" style="width: 10%;">Phân quyền</th>
                            <th class="py-3 text-center" style="width: 10%;">Trạng thái</th>
                            <th class="py-3 text-center" style="width: 10%;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-dark">@item.FullName</td>
                                    <td><span class="text-secondary">@item.Username</span></td>
                                    <td class="fw-bold">@item.Phone</td>
                                    <td>@item.Email</td>

                                    <td class="text-center">
                                        @if (item.Role == "Admin")
                                        {
                                            <span class="badge bg-danger rounded-pill px-3 py-2 shadow-sm">
                                                Admin
                                            </span>
                                        }
                                        else if (item.Role == "Employee")
                                        {
                                            <span class="badge bg-info text-dark rounded-pill px-3 py-2 shadow-sm">
                                                Nhân viên
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary rounded-pill px-3 py-2 shadow-sm">
                                                Khách hàng
                                            </span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success rounded-pill shadow-sm"><i class="bi bi-check-circle"></i> Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary rounded-pill shadow-sm"><i class="bi bi-lock-fill"></i> Đã khóa</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.UserId"
                                               class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                               onclick="return confirm('Bạn có chắc chắn muốn @(item.IsActive ? "KHÓA" : "MỞ KHÓA") tài khoản của @item.FullName không?');"
                                               title="@(item.IsActive ? "Khóa tài khoản" : "Mở khóa tài khoản")">
                                                <i class="fa-solid @(item.IsActive ? "fa-lock" : "fa-lock-open")"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted fw-bold fs-5">
                                    Chưa có dữ liệu người dùng nào trong hệ thống!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4 mb-5">
        <ul class="pagination justify-content-center shadow-sm">

            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link fw-bold" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-searchString="@ViewBag.SearchString"
                   asp-route-role="@ViewBag.Role"
                   asp-route-isActive="@ViewBag.IsActive">❮ Trước</a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link fw-bold" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-searchString="@ViewBag.SearchString"
                       asp-route-role="@ViewBag.Role"
                       asp-route-isActive="@ViewBag.IsActive">@i</a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link fw-bold" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-searchString="@ViewBag.SearchString"
                   asp-route-role="@ViewBag.Role"
                   asp-route-isActive="@ViewBag.IsActive">Sau ❯</a>
            </li>

        </ul>
    </nav>
}
<style>
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: background-color 0.2s ease-in-out;
    }
</style>