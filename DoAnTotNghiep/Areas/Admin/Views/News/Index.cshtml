@model IEnumerable<DoAnTotNghiep.Models.News>

@{
    ViewData["Title"] = "Quản lý Tin tức";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">📰 Danh sách Tin tức</h2>
        <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm rounded-pill px-4">
            ➕ Thêm bài viết mới
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4 bg-light">
        <div class="card-body p-3">
            <form asp-action="Index" method="get">
                <div class="row">
                    <div class="col-md-6 col-lg-5">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-2">🔍 Tìm kiếm bài viết</label>

                        <div class="input-group shadow-sm">
                            <input type="text" name="searchString" class="form-control border-secondary" value="@ViewBag.SearchString" placeholder="Nhập tiêu đề bài viết...">

                            <button type="submit" class="btn btn-primary fw-bold px-4">Tìm kiếm</button>

                            @if (!string.IsNullOrEmpty(ViewBag.SearchString))
                            {
                                <a asp-action="Index" class="btn btn-outline-danger fw-bold px-3" title="Xóa tìm kiếm">❌</a>
                            }
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="py-3 px-4 text-center" style="width: 15%;">Ảnh</th>
                            <th class="py-3" style="width: 35%;">Tiêu đề</th>
                            <th class="py-3" style="width: 20%;">Đăng bởi</th>
                            <th class="py-3" style="width: 15%;">Sửa lần cuối</th>
                            <th class="py-3 text-center" style="width: 15%;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center py-2 px-4">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.Title" class="img-fluid rounded shadow-sm bg-white p-1" style="height: 60px; width: 100px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Chưa có ảnh</span>
                                        }
                                    </td>

                                    <td class="fw-bold text-dark fs-6">
                                        <div style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">
                                            @item.Title
                                        </div>
                                    </td>

                                    <td>
                                        <span class="d-block text-muted small">@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                                        <span class="badge bg-success">@item.CreatedBy</span>
                                    </td>

                                    <td>
                                        @if (item.UpdatedDate.HasValue)
                                        {
                                            <span class="d-block text-muted small">@item.UpdatedDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                            <span class="badge bg-warning text-dark">@item.UpdatedBy</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small fst-italic">Chưa chỉnh sửa</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Edit" asp-route-id="@item.NewsId" class="btn btn-sm btn-outline-primary" title="Sửa">✏️ Sửa</a>
                                            <a asp-action="Delete" asp-route-id="@item.NewsId" class="btn btn-sm btn-outline-danger" title="Xóa">🗑️ Xóa</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted fw-bold fs-5">
                                    📭 Chưa có bài viết nào phù hợp!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4 mb-5">
        <ul class="pagination justify-content-center shadow-sm">

            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link fw-bold" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-searchString="@ViewBag.SearchString">❮ Trước</a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link fw-bold" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-searchString="@ViewBag.SearchString">@i</a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link fw-bold" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-searchString="@ViewBag.SearchString">Sau ❯</a>
            </li>

        </ul>
    </nav>
}

<style>
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: background-color 0.2s ease-in-out;
    }
</style>