@model IEnumerable<DoAnTotNghiep.Models.Review>

@{
    ViewData["Title"] = "Quản lý Đánh giá";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4 mb-5">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show fw-bold shadow-sm">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">⭐ QUẢN LÝ ĐÁNH GIÁ & BÌNH LUẬN</h2>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4 bg-light">
        <div class="card-body p-3">
            <form asp-action="Index" method="get">
                @{
                    bool? currentStatus = ViewBag.IsApproved as bool?;
                    int? currentRating = ViewBag.Rating as int?;
                }
                <div class="row g-2 align-items-end">

                    <div class="col-md-4">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">🔍 Tìm kiếm</label>
                        <input type="text" name="searchString" class="form-control border-secondary" value="@ViewBag.SearchString" placeholder="Tìm tên khách, sản phẩm, nội dung...">
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">Trạng thái hiển thị</label>
                        <select name="isApproved" class="form-select border-secondary">
                            <option value="">-- Tất cả --</option>
                            <option value="true" selected="@(currentStatus == true)">🟢 Đang hiển thị</option>
                            <option value="false" selected="@(currentStatus == false)">🔴 Bị ẩn</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">Đánh giá sao</label>
                        <select name="rating" class="form-select border-secondary">
                            <option value="">-- Tất cả số sao --</option>
                            <option value="5" selected="@(currentRating == 5)">⭐⭐⭐⭐⭐ (5 sao)</option>
                            <option value="4" selected="@(currentRating == 4)">⭐⭐⭐⭐ (4 sao)</option>
                            <option value="3" selected="@(currentRating == 3)">⭐⭐⭐ (3 sao)</option>
                            <option value="2" selected="@(currentRating == 2)">⭐⭐ (2 sao)</option>
                            <option value="1" selected="@(currentRating == 1)">⭐ (1 sao)</option>
                        </select>
                    </div>

                    <div class="col-md-2 d-flex gap-2">
                        <button type="submit" class="btn btn-primary fw-bold flex-grow-1 shadow-sm">Lọc</button>

                        @if (!string.IsNullOrEmpty(ViewBag.SearchString) || currentStatus != null || currentRating != null)
                        {
                            <a asp-action="Index" class="btn btn-outline-danger fw-bold px-3 shadow-sm" title="Xóa bộ lọc">❌</a>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="table-layout: fixed; word-wrap: break-word;">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="py-3 px-4" style="width: 20%;">Sản phẩm</th>
                            <th class="py-3" style="width: 35%;">Khách hàng & Nội dung</th>
                            <th class="py-3 text-center" style="width: 15%;">Đánh giá</th>
                            <th class="py-3 text-center" style="width: 15%;">Trạng thái</th>
                            <th class="py-3 text-center" style="width: 15%;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr class="@(item.IsApproved ? "" : "bg-light text-muted")">
                                    <td class="px-4 fw-bold text-primary small">
                                        <div style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                            @item.Product?.ProductName
                                        </div>
                                    </td>

                                    <td>
                                        <span class="d-block fw-bold text-dark fs-6">@item.UserName <span class="text-muted fw-normal small">(@item.CreatedDate.ToString("dd/MM/yyyy HH:mm"))</span></span>
                                        <div class="mt-1 @(item.IsApproved ? "text-dark" : "text-muted")" style="max-height: 60px; overflow: hidden; text-overflow: ellipsis; font-style: italic;">
                                            "@item.Comment"
                                        </div>
                                    </td>

                                    <td class="text-center text-warning fs-5">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= item.Rating)
                                            {
                                                <span>★</span>
                                            }
                                            else
                                            {

                                                <span class="text-muted opacity-25">★</span>
                                            }
                                        }
                                    </td>

                                    <td class="text-center">
                                        @if (item.IsApproved)
                                        {
                                            <span class="badge bg-success shadow-sm px-3 py-2">Đang hiện</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary shadow-sm px-3 py-2">Đã bị ẩn</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            @if (item.IsApproved)
                                            {
                                                <a asp-action="ToggleStatus" asp-route-id="@item.ReviewId" class="btn btn-sm btn-warning text-dark fw-bold" onclick="return confirm('Bạn muốn ẨN bình luận này khỏi trang sản phẩm?');" title="Ẩn bình luận">👁️ Ẩn</a>
                                            }
                                            else
                                            {
                                                <a asp-action="ToggleStatus" asp-route-id="@item.ReviewId" class="btn btn-sm btn-success fw-bold" onclick="return confirm('Bạn muốn HIỂN THỊ lại bình luận này?');" title="Hiện bình luận">✔️ Hiện</a>
                                            }
                                            <a asp-action="Delete" asp-route-id="@item.ReviewId" class="btn btn-sm btn-outline-danger"
                                               onclick="return confirm('XÓA VĨNH VIỄN bình luận của [@item.UserName]?');" title="Xóa">🗑️</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted fw-bold fs-5">
                                    📭 Chưa có đánh giá nào trong hệ thống!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    bool? filterStatus = ViewBag.IsApproved as bool?;
    int? filterRating = ViewBag.Rating as int?;

    <nav aria-label="Page navigation" class="mt-4 mb-5">
        <ul class="pagination justify-content-center shadow-sm">

            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link fw-bold" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-searchString="@ViewBag.SearchString"
                   asp-route-isApproved="@filterStatus"
                   asp-route-rating="@filterRating">❮ Trước</a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link fw-bold" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-searchString="@ViewBag.SearchString"
                       asp-route-isApproved="@filterStatus"
                       asp-route-rating="@filterRating">@i</a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link fw-bold" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-searchString="@ViewBag.SearchString"
                   asp-route-isApproved="@filterStatus"
                   asp-route-rating="@filterRating">Sau ❯</a>
            </li>

        </ul>
    </nav>
}
