@model IEnumerable<DoAnTotNghiep.Models.Review>

@{
    ViewData["Title"] = "Quản lý Đánh giá";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4 mb-5">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show fw-bold shadow-sm">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0"><i class="fas fa-comments me-2"></i>QUẢN LÝ ĐÁNH GIÁ & BÌNH LUẬN</h2>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4 bg-light">
        <div class="card-body p-3">
            <form asp-action="Index" method="get">
                @{
                    bool? currentStatus = ViewBag.IsApproved as bool?;
                    int? currentRating = ViewBag.Rating as int?;
                }
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">Tìm kiếm</label>
                        <input type="text" name="searchString" class="form-control border-secondary" value="@ViewBag.SearchString" placeholder="Tìm tên khách, sản phẩm, nội dung...">
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">Trạng thái hiển thị</label>
                        <select name="isApproved" class="form-select border-secondary">
                            <option value="">-- Tất cả --</option>
                            <option value="true" selected="@(currentStatus == true)">Đang hiển thị</option>
                            <option value="false" selected="@(currentStatus == false)">Bị ẩn</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold text-muted small text-uppercase mb-1">Đánh giá sao</label>
                        <select name="rating" class="form-select border-secondary">
                            <option value="">-- Tất cả số sao --</option>
                            <option value="5" selected="@(currentRating == 5)">5 sao</option>
                            <option value="4" selected="@(currentRating == 4)">4 sao</option>
                            <option value="3" selected="@(currentRating == 3)">3 sao</option>
                            <option value="2" selected="@(currentRating == 2)">2 sao</option>
                            <option value="1" selected="@(currentRating == 1)">1 sao</option>
                        </select>
                    </div>

                    <div class="col-md-2 d-flex gap-2">
                        <button type="submit" class="btn btn-primary fw-bold flex-grow-1 shadow-sm">Lọc</button>

                        @if (!string.IsNullOrEmpty(ViewBag.SearchString) || currentStatus != null || currentRating != null)
                        {
                            <a asp-action="Index" class="btn btn-outline-danger fw-bold px-3 shadow-sm" title="Xóa bộ lọc"><i class="fa-solid fa-xmark"></i></a>
                        }
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="table-layout: fixed; word-wrap: break-word;">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="py-3 px-4" style="width: 20%;">Sản phẩm</th>
                            <th class="py-3" style="width: 35%;">Khách hàng & Nội dung</th>
                            <th class="py-3 text-center" style="width: 15%;">Đánh giá</th>
                            <th class="py-3 text-center" style="width: 12%;">Trạng thái</th>
                            <th class="py-3 text-center" style="width: 18%;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                int likeCount = item.ReviewLikes?.Count ?? 0;

                                <tr class="@(item.IsApproved ? "" : "bg-light text-muted")">
                                    <td class="px-4 fw-bold text-primary small">
                                        <div style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                            @item.Product?.ProductName
                                        </div>
                                    </td>

                                    <td>
                                        <span class="d-block fw-bold text-dark fs-6">@item.UserName <span class="text-muted fw-normal small">(@item.CreatedDate.ToString("dd/MM/yyyy HH:mm"))</span></span>
                                        <div class="mt-1 @(item.IsApproved ? "text-dark" : "text-muted")">
                                            @item.Comment
                                        </div>

                                        @if (!string.IsNullOrEmpty(item.AdminReply))
                                        {
                                            <div class="mt-2 p-2 bg-light border-start border-3 border-primary rounded text-dark small position-relative">
                                                <i class="fas fa-reply text-primary me-1"></i> <span class="fw-bold">Phản hồi của bạn:</span>
                                                <div class="mt-1 fst-italic">"@item.AdminReply"</div>
                                                <small class="text-muted d-block mt-1">Lúc: @item.RepliedAt?.ToString("dd/MM/yyyy HH:mm")</small>
                                            </div>
                                        }

                                        @if (likeCount > 0)
                                        {
                                            <button type="button" class="btn btn-sm btn-link text-decoration-none text-primary p-0 mt-2 fw-bold" onclick="showLikesModal(@item.ReviewId)">
                                                <i class="fas fa-thumbs-up me-1"></i> Hữu ích (@likeCount)
                                            </button>
                                        }
                                    </td>

                                    <td class="text-center text-warning fs-5">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= item.Rating)
                                            {
                                                <span><i class="fa-solid fa-star"></i></span>
                                            }
                                            else
                                            {
                                                <span class="text-muted opacity-25"><i class="fa-regular fa-star text-muted opacity-50"></i></span>
                                            }
                                        }
                                    </td>

                                    <td class="text-center">
                                        @if (item.IsApproved)
                                        {
                                            <span class="badge bg-success shadow-sm px-3 py-2">Đang hiện</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary shadow-sm px-3 py-2">Đã bị ẩn</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            <button type="button" class="btn btn-sm btn-outline-info" onclick="openReplyModal(@item.ReviewId, `@Html.Raw(item.AdminReply?.Replace("`", "\\`") ?? "")`)" title="Phản hồi bình luận này">
                                                <i class="fas fa-reply"></i>
                                            </button>

                                            @if (item.IsApproved)
                                            {
                                                <a asp-action="ToggleStatus" asp-route-id="@item.ReviewId" class="btn btn-sm btn-warning text-dark fw-bold" onclick="return confirm('Bạn muốn ẨN bình luận này khỏi trang sản phẩm?');" title="Ẩn bình luận"><i class="fa-solid fa-eye-slash"></i></a>
                                            }
                                            else
                                            {
                                                <a asp-action="ToggleStatus" asp-route-id="@item.ReviewId" class="btn btn-sm btn-success fw-bold" onclick="return confirm('Bạn muốn HIỂN THỊ lại bình luận này?');" title="Hiện bình luận"><i class="fa-solid fa-eye"></i></a>
                                            }
                                            <a asp-action="Delete" asp-route-id="@item.ReviewId" class="btn btn-sm btn-outline-danger"
                                               onclick="return confirm('XÓA VĨNH VIỄN bình luận của [@item.UserName]?');" title="Xóa"><i class="fas fa-trash-alt"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted fw-bold fs-5">
                                    Chưa có đánh giá nào trong hệ thống!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="replyModal" tabindex="-1" aria-labelledby="replyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white rounded-top-4">
                <h5 class="modal-title fw-bold" id="replyModalLabel"><i class="fas fa-reply me-2"></i>Phản hồi Đánh giá</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Reply" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" name="reviewId" id="replyReviewId" />
                    <div class="mb-3">
                        <label for="adminReply" class="form-label fw-bold">Nội dung câu trả lời của Admin:</label>
                        <textarea class="form-control bg-light" id="adminReply" name="adminReply" rows="4" placeholder="Nhập câu trả lời để hiển thị công khai cho khách hàng xem..." required></textarea>
                        <small class="text-muted fst-italic mt-2 d-block">Lưu ý: Nếu bạn xóa trống nội dung và bấm Lưu, hệ thống sẽ tự động gỡ bỏ phản hồi.</small>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary fw-bold shadow-sm px-4">Lưu câu trả lời</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="likesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-light border-0">
                <h6 class="modal-title fw-bold text-primary"><i class="fas fa-thumbs-up me-2"></i>Danh sách Hữu ích</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <ul class="list-group list-group-flush" id="likesListContainer">
                    <li class="list-group-item text-center py-4 text-muted"><i class="fas fa-spinner fa-spin me-2"></i>Đang tải...</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    bool? filterStatus = ViewBag.IsApproved as bool?;
    int? filterRating = ViewBag.Rating as int?;

    <nav aria-label="Page navigation" class="mt-4 mb-5">
        <ul class="pagination justify-content-center shadow-sm">
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link fw-bold" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-searchString="@ViewBag.SearchString"
                   asp-route-isApproved="@filterStatus"
                   asp-route-rating="@filterRating">❮ Trước</a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link fw-bold" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-searchString="@ViewBag.SearchString"
                       asp-route-isApproved="@filterStatus"
                       asp-route-rating="@filterRating">@i</a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link fw-bold" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-searchString="@ViewBag.SearchString"
                   asp-route-isApproved="@filterStatus"
                   asp-route-rating="@filterRating">Sau ❯</a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        // Mở Modal Phản hồi Đánh giá
        function openReplyModal(reviewId, currentReply) {
            document.getElementById('replyReviewId').value = reviewId;

            let textarea = document.getElementById('adminReply');
            textarea.value = currentReply || ''; // Nếu đã có trả lời thì điền sẵn vào ô, chưa có thì để trống

            // Xóa validation required nếu đã có trả lời (Để cho phép Admin xóa sạch text để gỡ bỏ phản hồi)
            if (currentReply) {
                textarea.removeAttribute("required");
            } else {
                textarea.setAttribute("required", "required");
            }

            var replyModal = new bootstrap.Modal(document.getElementById('replyModal'));
            replyModal.show();
        }

        // Gọi AJAX lấy danh sách người đã thả Hữu ích (Like)
        function showLikesModal(reviewId) {
            var likesModal = new bootstrap.Modal(document.getElementById('likesModal'));
            likesModal.show();

            let container = document.getElementById('likesListContainer');
            container.innerHTML = '<li class="list-group-item text-center py-4 text-muted"><i class="fas fa-spinner fa-spin me-2"></i>Đang tải dữ liệu...</li>';

            fetch(`@Url.Action("GetLikes", "Review", new { area = "Admin" })?reviewId=${reviewId}`)
                .then(response => response.json())
                .then(data => {
                    if (data && data.length > 0) {
                        let html = '';
                        data.forEach(user => {
                            html += `
                            <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <i class="fas fa-user-circle text-secondary fs-5 me-2"></i>
                                    <span class="fw-bold text-dark">${user.userName}</span>
                                </div>
                                <span class="badge bg-light text-secondary border small">${user.createdAt}</span>
                            </li>`;
                        });
                        container.innerHTML = html;
                    } else {
                        container.innerHTML = '<li class="list-group-item text-center py-4 text-muted fw-bold">Không tìm thấy dữ liệu.</li>';
                    }
                })
                .catch(error => {
                    console.error('Error fetching likes:', error);
                    container.innerHTML = '<li class="list-group-item text-center py-4 text-danger fw-bold">Lỗi kết nối máy chủ!</li>';
                });
        }
    </script>
}