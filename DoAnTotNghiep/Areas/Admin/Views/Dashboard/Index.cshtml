@{
    ViewData["Title"] = "Bảng điều khiển Quản trị";
}

<div class="container-fluid mt-4 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">THỐNG KÊ SỐ LIỆU</h2>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white shadow border-0 h-100 rounded-3">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-uppercase mb-2">DOANH THU</h6>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalRevenue.ToString("#,##0") đ</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white shadow border-0 h-100 rounded-3">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-uppercase mb-2">TỔNG ĐƠN ĐÃ ĐẶT</h6>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalOrders <span class="fs-6 fw-normal">đơn</span></h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark shadow border-0 h-100 rounded-3">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-uppercase mb-2">KHO SẢN PHẨM</h6>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalProducts <span class="fs-6 fw-normal">mặt hàng</span></h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-dark text-white shadow border-0 h-100 rounded-3">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-uppercase mb-2">KHÁCH HÀNG</h6>
                    <h3 class="fw-bold mb-0">@ViewBag.TotalCustomers <span class="fs-6 fw-normal">thành viên</span></h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-warning border-start border-5 shadow-sm h-100 rounded-3">
                <div class="card-body p-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="fw-bold text-warning text-uppercase mb-1">Chờ xác nhận</h6>
                        <h4 class="fw-bold text-dark mb-0">@ViewBag.PendingOrders</h4>
                    </div>
                    <i class="fas fa-clock fa-2x text-warning opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-success border-start border-5 shadow-sm h-100 rounded-3">
                <div class="card-body p-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="fw-bold text-success text-uppercase mb-1">Giao thành công</h6>
                        <h4 class="fw-bold text-dark mb-0">@ViewBag.SuccessOrders</h4>
                    </div>
                    <i class="fas fa-check-circle fa-2x text-success opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-danger border-start border-5 shadow-sm h-100 rounded-3">
                <div class="card-body p-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="fw-bold text-danger text-uppercase mb-1">Đơn bị hủy/Bom</h6>
                        <h4 class="fw-bold text-dark mb-0">@ViewBag.CanceledOrders</h4>
                    </div>
                    <i class="fas fa-times-circle fa-2x text-danger opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span class="fw-bold fs-5">Doanh thu theo ngày</span>

                    <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center m-0">
                        <input type="hidden" name="selectedYear" value="@ViewBag.SelectedYear" />

                        <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control form-control-sm bg-light border-0" required />
                        <span class="text-muted fw-bold">-</span>
                        <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control form-control-sm bg-light border-0" required />
                        <button type="submit" class="btn btn-sm btn-primary fw-bold px-3">Lọc</button>
                    </form>
                </div>
                <div class="card-body">
                    @if (string.IsNullOrEmpty(ViewBag.ChartData))
                    {
                        <div class="d-flex justify-content-center align-items-center h-100 text-muted">
                            <h5>Không có doanh thu trong khoảng thời gian này.</h5>
                        </div>
                    }
                    else
                    {
                        <canvas id="revenueChart" style="min-height: 350px;"></canvas>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white fw-bold py-3 fs-5 d-flex justify-content-between align-items-center">
                    <span>Top 5 Sản phẩm bán chạy</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Sản phẩm</th>
                                    <th class="text-center">Đã bán</th>
                                    <th class="text-end pe-3">Doanh thu</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.TopSellingProducts != null)
                                {
                                    var topProducts = ViewBag.TopSellingProducts as IEnumerable<dynamic>;
                                    if (topProducts != null && topProducts.Any())
                                    {
                                        int rank = 1;
                                        foreach (var item in topProducts)
                                        {
                                            <tr>
                                                <td class="ps-3 d-flex align-items-center gap-2">
                                                    @if (rank == 1)
                                                    {
                                                        <span class="badge bg-warning text-dark fs-6" title="Top 1">🥇</span>
                                                    }
                                                    else if (rank == 2)
                                                    {

                                                        <span class="badge bg-secondary fs-6" title="Top 2">🥈</span>
                                                    }
                                                    else if (rank == 3)
                                                    {

                                                        <span class="badge bg-danger fs-6" title="Top 3">🥉</span>
                                                    }
                                                    else
                                                    {

                                                        <span class="badge bg-light text-dark border ms-1" style="width: 25px;">@rank</span>
                                                    }

                                                    <img src="@item.ImageUrl" class="rounded border" style="width: 40px; height: 40px; object-fit: contain; background: white;" />
                                                    <div class="fw-bold text-dark" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; max-width: 150px; font-size: 0.9rem;">
                                                        @item.ProductName
                                                    </div>
                                                </td>
                                                <td class="text-center">
                                                    <span class="badge bg-success shadow-sm fs-6">@item.TotalSold</span>
                                                </td>
                                                <td class="text-end pe-3 fw-bold text-danger">
                                                    @item.TotalRevenue.ToString("#,##0") đ
                                                </td>
                                            </tr>
                                            rank++;
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="3" class="text-center text-muted py-5">Chưa có dữ liệu bán hàng.</td></tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="3" class="text-center text-muted py-5">Chưa có dữ liệu bán hàng.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-12">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <span class="fw-bold fs-5">Doanh thu các tháng</span>

                    <form asp-action="Index" method="get" class="m-0">
                        <input type="hidden" name="startDate" value="@ViewBag.StartDate" />
                        <input type="hidden" name="endDate" value="@ViewBag.EndDate" />

                        <select name="selectedYear" class="form-select form-select-sm fw-bold bg-light border-0 text-primary" onchange="this.form.submit()" style="cursor: pointer;">
                            @if (ViewBag.AvailableYears != null)
                            {
                                foreach (var year in ViewBag.AvailableYears)
                                {
                                    if (year == ViewBag.SelectedYear)
                                    {
                                        <option value="@year" selected>Năm @year</option>
                                    }
                                    else
                                    {
                                        <option value="@year">Năm @year</option>
                                    }
                                }
                            }
                        </select>
                    </form>
                </div>
                <div class="card-body">
                    @if (string.IsNullOrEmpty(ViewBag.MonthlyData))
                    {
                        <div class="text-center text-muted py-5">Chưa có dữ liệu.</div>
                    }
                    else
                    {
                        <canvas id="monthlyChart" style="min-height: 350px;"></canvas>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // ==========================================
        // VẼ BIỂU ĐỒ THEO NGÀY
        // ==========================================
        var labelsStr = '@Html.Raw(ViewBag.ChartLabels)';
        var dataStr = '@ViewBag.ChartData';

        if(labelsStr && dataStr) {
            var chartLabels = labelsStr.split(',');
            var chartData = dataStr.split(',').map(Number);

            var ctx = document.getElementById('revenueChart').getContext('2d');
            var revenueChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: chartLabels,
                    datasets: [{
                        label: 'Doanh thu (VNĐ)',
                        data: chartData,
                        backgroundColor: 'rgba(54, 162, 235, 0.6)',
                        borderColor: 'rgba(54, 162, 235, 1)',
                        borderWidth: 1,
                        borderRadius: 5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return value.toLocaleString('vi-VN') + ' đ';
                                }
                            }
                        }
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.parsed.y.toLocaleString('vi-VN') + ' đ';
                                }
                            }
                        }
                    }
                }
            });
        }

        // ==========================================
        // VẼ BIỂU ĐỒ THEO THÁNG
        // ==========================================
        var mLabelsStr = '@Html.Raw(ViewBag.MonthlyLabels)';
        var mDataStr = '@ViewBag.MonthlyData';

        if(mLabelsStr && mDataStr) {
            var ctxMonth = document.getElementById('monthlyChart').getContext('2d');
            new Chart(ctxMonth, {
                type: 'bar',
                data: {
                    labels: mLabelsStr.split(','),
                    datasets: [{
                        label: 'Doanh thu (VNĐ)',
                        data: mDataStr.split(',').map(Number),
                        backgroundColor: 'rgba(75, 192, 192, 0.6)',
                        borderColor: 'rgba(75, 192, 192, 1)',
                        borderWidth: 1, borderRadius: 4
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true, ticks: { callback: function(v) { return v.toLocaleString('vi-VN') + ' đ'; } } } },
                    plugins: { tooltip: { callbacks: { label: function(c) { return c.parsed.y.toLocaleString('vi-VN') + ' đ'; } } } }
                }
            });
        }
    </script>
}