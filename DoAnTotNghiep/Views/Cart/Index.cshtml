@model List<DoAnTotNghiep.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}
<div class="container mt-4 mb-5">
    <h2 class="fw-bold text-center mb-4">🛒 GIỎ HÀNG CỦA BẠN</h2>
    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info text-center fw-bold p-5 shadow-sm">
            Giỏ hàng đang trống. <a asp-controller="Product" asp-action="Index" class="text-danger text-decoration-none">Tiếp tục mua sắm ngay!</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">Đơn giá</th>
                            <th class="text-center" style="width: 150px;">Số lượng</th>
                            <th class="text-end">Thành tiền</th>
                            <th class="text-center">Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="@item.ThumbnailUrl" style="width: 60px; height: 60px; object-fit: contain;" class="me-3 border rounded p-1" />
                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="fw-bold text-dark text-decoration-none">
                                            @item.ProductName
                                        </a>
                                    </div>
                                </td>
                                <td class="text-center text-danger fw-bold">@item.Price.ToString("#,##0") đ</td>

                                <td class="text-center">
                                    <input type="number" class="form-control text-center mx-auto quantity-input" data-id="@item.ProductId" value="@item.Quantity" min="1" style="width: 80px;" />
                                </td>

                                <td class="text-end text-danger fw-bold fs-5" id="item-total-@item.ProductId">
                                    @item.TotalAmount.ToString("#,##0") đ
                                </td>

                                <td class="text-center">
                                    <a asp-action="RemoveFromCart" asp-route-id="@item.ProductId" class="btn btn-outline-danger btn-sm">❌</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold fs-4">TỔNG CỘNG:</td>
                            <td colspan="2" class="text-end text-danger fw-bold fs-3" id="cart-grand-total">
                                @Model.Sum(x => x.TotalAmount).ToString("#,##0") đ
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <div class="card-footer bg-white p-3 d-flex justify-content-between align-items-center">
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary fw-bold">⬅ Tiếp tục mua sắm</a>
                <a asp-controller="Cart" asp-action="Checkout" class="btn btn-danger btn-lg fw-bold px-5">THANH TOÁN 💳</a>
            </div>
        </div>
    }
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            $('.quantity-input').on('input change', function () {
                var productId = $(this).data('id');
                var newQuantity = $(this).val();
                if (newQuantity === '' || newQuantity < 1) return;
                $.ajax({
                    url: '@Url.Action("UpdateQuantity", "Cart")',
                    type: 'POST',
                    data: {
                        id: productId,
                        quantity: newQuantity
                    },
                    success: function (response) {
                        if (response.success) {
                            $('#item-total-' + productId).text(response.itemTotal);
                            $('#cart-grand-total').text(response.cartTotal);
                        }
                    },
                    error: function () {
                        alert("Có lỗi kết nối! Vui lòng tải lại trang.");
                    }
                });
            });
        });
    </script>
}