@{
    ViewData["Title"] = "Đặt hàng thành công";
}
<div class="container mt-5 mb-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-success">
                <div class="card-body p-5">
                    <h1 class="display-1 text-success mb-3">✅</h1>
                    <h2 class="text-success fw-bold mb-3">ĐẶT HÀNG THÀNH CÔNG!</h2>
                    <p class="fs-5 mb-4">
                        Cảm ơn bạn đã mua sắm tại MyShop. Mã đơn hàng của bạn là:
                        <strong class="text-danger fs-4">#@ViewBag.OrderId</strong>
                    </p>
                    <p class="text-muted mb-5">
                        Chúng tôi sẽ liên hệ với bạn qua số điện thoại đã cung cấp để xác nhận đơn hàng trong thời gian sớm nhất.
                    </p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg fw-bold px-5">
                        ⬅ QUAY VỀ TRANG CHỦ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>