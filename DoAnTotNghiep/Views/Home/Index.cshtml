@model IEnumerable<DoAnTotNghiep.Models.Slider>

@{
    ViewData["Title"] = "Trang chủ - Cửa hàng đồ công nghệ";
    var promoDict = ViewBag.PromoDict as Dictionary<int, int>;
    var favoritedIds = ViewBag.FavoritedIds as List<int> ?? new List<int>();

    // =========================================================================
    // HÀM 1: LẤY BIẾN THỂ CÓ GIÁ RẺ NHẤT (ĐỂ HIỂN THỊ ĐẠI DIỆN NGOÀI TRANG CHỦ)
    // =========================================================================
    (DoAnTotNghiep.Models.ProductVariant BestVariant, int Discount, decimal SalePrice) GetBestVariantInfo(IEnumerable<DoAnTotNghiep.Models.ProductVariant> variants)
    {
        if (variants == null || !variants.Any()) return (null, 0, 0);

        var best = variants.Select(v =>
        {
            int disc = (promoDict != null && promoDict.ContainsKey(v.VariantId)) ? promoDict[v.VariantId] : 0;
            decimal sPrice = v.Price - (v.Price * disc / 100m);
            return new { Variant = v, Discount = disc, SalePrice = sPrice };
        }).OrderBy(x => x.SalePrice).First();

        return (best.Variant, best.Discount, best.SalePrice);
    }

    // =========================================================================
    // HÀM 2: RENDER GIAO DIỆN THẺ SẢN PHẨM DÙNG CHUNG
    // =========================================================================
    void RenderProductCard(DoAnTotNghiep.Models.Product item, string title, string imgUrl, decimal basePrice, decimal salePrice, bool isSale, int discount, string prefix, string badgeLeft, string badgeLeftClass, string borderColorClass, int variantId)
    {
        var approvedReviews = item.Reviews?.Where(r => r.IsApproved).ToList() ?? new List<DoAnTotNghiep.Models.Review>();
        double avgRating = approvedReviews.Any() ? Math.Round(approvedReviews.Average(r => r.Rating), 1) : 0;
        int totalReviews = approvedReviews.Count;
        bool isFav = favoritedIds.Contains(item.ProductId);

        <div class="carousel-item-card px-2">
            <div class="card h-100 shadow-sm @borderColorClass product-card transition-hover position-relative bg-white">

                @if (isSale)
                {
                    <div class="position-absolute top-0 end-0 bg-danger text-white fw-bold px-2 py-1 m-2 rounded-circle shadow" style="z-index: 2;">
                        -@discount%
                    </div>
                }

                @if (!string.IsNullOrEmpty(badgeLeft))
                {
                    <div class="position-absolute top-0 start-0 @badgeLeftClass fw-bold px-2 py-1 m-2 rounded shadow-sm" style="z-index: 2; font-size: 0.75rem;">
                        @badgeLeft
                    </div>
                }

                <a href="/Product/Details/@item.ProductId?variantId=@variantId">
                    <img src="@imgUrl" class="card-img-top p-3" alt="@title" style="height: 220px; object-fit: contain;">
                </a>

                <div class="card-body d-flex flex-column text-start">
                    <h6 class="card-title fw-bold mb-3" style="height: 42px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                        <a href="/Product/Details/@item.ProductId?variantId=@variantId" class="text-dark text-decoration-none hover-primary">
                            @title
                        </a>
                    </h6>

                    <div class="mt-auto">
                        <div class="mb-3">
                            @if (basePrice > 0)
                            {
                                @if (isSale)
                                {
                                    <div class="text-danger fw-bold fs-5 mb-1">
                                        @prefix @salePrice.ToString("#,##0") đ
                                    </div>
                                    <div class="text-muted text-decoration-line-through" style="font-size: 0.85rem;">
                                        @basePrice.ToString("#,##0") đ
                                    </div>
                                }
                                else
                                {
                                    <div class="text-danger fw-bold fs-5">@prefix @basePrice.ToString("#,##0") đ</div>
                                }
                            }
                            else
                            {
                                <span class="text-secondary fw-bold fs-6 fst-italic px-3 py-1 bg-light rounded-pill border">Sắp về hàng</span>
                            }
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                            <div class="d-flex align-items-center">
                                <div class="text-warning fw-bold me-1" style="font-size: 0.95rem;">
                                    @avgRating.ToString("0.0") <i class="fas fa-star"></i>
                                </div>
                                <span class="text-muted fw-bold" style="font-size: 0.8rem;">(@totalReviews)</span>
                            </div>

                            <button class="btn btn-sm border-0 rounded-circle shadow-none heart-btn @(isFav ? "liked" : "")"
                                    onclick="toggleFavorite(this, @item.ProductId)" title="Thêm vào yêu thích">
                                <i class="@(isFav ? "fas" : "far") fa-heart fs-5"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}

<div class="container mb-5">

    @if (Model != null && Model.Any())
    {
        <div id="mainSlider" class="carousel slide shadow-lg" data-bs-ride="carousel" style="border-radius: 15px; overflow: hidden;">
            <div class="carousel-indicators">
                @{
                    int indicatorIndex = 0;
                }
                @foreach (var item in Model)
                {
                    <button type="button" data-bs-target="#mainSlider" data-bs-slide-to="@indicatorIndex" class="@(indicatorIndex == 0 ? "active" : "")" aria-current="@(indicatorIndex == 0 ? "true" : "false")"></button>
                    indicatorIndex++;
                }
            </div>
            <div class="carousel-inner">
                @{
                    int itemIndex = 0;
                }
                @foreach (var item in Model)
                {
                    <div class="carousel-item @(itemIndex == 0 ? "active" : "")" data-bs-interval="4000">
                        <img src="@item.ImageUrl" class="d-block w-100" alt="@item.Title" style="height: 450px; object-fit: cover;">
                        @if (!string.IsNullOrEmpty(item.Title) || !string.IsNullOrEmpty(item.Description))
                        {
                            <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                                @if (!string.IsNullOrEmpty(item.Title))
                                {
                                    <h2 class="fw-bold text-warning">@item.Title</h2>
                                }
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <p class="fs-5 text-white">@item.Description</p>
                                }
                            </div>
                        }
                    </div>
                    itemIndex++;
                }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#mainSlider" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span><span class="visually-hidden">Trước</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#mainSlider" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span><span class="visually-hidden">Sau</span>
            </button>
        </div>
    }

    @if (ViewBag.SaleProducts != null)
    {
        <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2 mt-5">
            <h3 class="fw-bold text-uppercase text-warning m-0">
                <i class="bi bi-lightning-charge-fill text-danger"></i> SẢN PHẨM KHUYẾN MÃI
            </h3>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-danger top-slider-btn shadow-sm" onclick="scrollCarousel('saleProductsCarousel', -1)">❮</button>
                <button class="btn btn-outline-danger top-slider-btn shadow-sm" onclick="scrollCarousel('saleProductsCarousel', 1)">❯</button>
            </div>
        </div>
        <div>
            <div class="product-carousel" id="saleProductsCarousel">
                @foreach (DoAnTotNghiep.Models.Product item in ViewBag.SaleProducts)
                {
                    var configGroups = item.ProductVariants?.Where(v => v.AttributeValues != null)
                    .Select(v => new
                    {
                        Variant = v,
                        ConfigName = v.AttributeValues.FirstOrDefault(a => a.PredefinedAttributeValue?.ProductAttribute?.AttributeName.ToLower().Contains("dung lượng") == true || a.PredefinedAttributeValue?.ProductAttribute?.AttributeName.ToLower().Contains("rom") == true)?.PredefinedAttributeValue?.Value
                    }).Where(x => !string.IsNullOrEmpty(x.ConfigName)).GroupBy(x => x.ConfigName).ToList();

                    if (configGroups != null && configGroups.Any())
                    {
                        foreach (var group in configGroups)
                        {
                            var info = GetBestVariantInfo(group.Select(g => g.Variant));
                            if (info.BestVariant == null) continue;

                            decimal basePrice = info.BestVariant.Price;
                            int discount = info.Discount;
                            bool isSale = discount > 0;
                            decimal salePrice = info.SalePrice;
                            string cardTitle = $"{item.ProductName} {group.Key}";
                            string imgUrl = !string.IsNullOrEmpty(info.BestVariant.ImageUrl) ? info.BestVariant.ImageUrl : item.ThumbnailUrl;

                            RenderProductCard(item, cardTitle, imgUrl, basePrice, salePrice, isSale, discount, "", "GIẢM SỐC", "bg-warning text-dark", "border-danger", info.BestVariant.VariantId);
                        }
                    }
                    else
                    {
                        var info = GetBestVariantInfo(item.ProductVariants);
                        decimal basePrice = info.BestVariant?.Price ?? 0;
                        int discount = info.Discount;
                        bool isSale = discount > 0;
                        decimal salePrice = info.SalePrice;
                        bool hasManyPrices = item.ProductVariants != null && item.ProductVariants.Select(v => v.Price).Distinct().Count() > 1;
                        string prefix = hasManyPrices ? "Giá từ: " : "";
                        int vId = info.BestVariant?.VariantId ?? 0;

                        RenderProductCard(item, item.ProductName, item.ThumbnailUrl, basePrice, salePrice, isSale, discount, prefix, "GIẢM SỐC", "bg-warning text-dark", "border-danger", vId);
                    }
                }
            </div>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2 mt-5">
        <h3 class="fw-bold text-uppercase text-primary m-0">Sản phẩm mới về</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary top-slider-btn shadow-sm" onclick="scrollCarousel('newProductsCarousel', -1)">❮</button>
            <button class="btn btn-outline-secondary top-slider-btn shadow-sm" onclick="scrollCarousel('newProductsCarousel', 1)">❯</button>
        </div>
    </div>
    <div>
        <div class="product-carousel" id="newProductsCarousel">
            @foreach (DoAnTotNghiep.Models.Product item in ViewBag.NewProducts)
            {
                var configGroups = item.ProductVariants?.Where(v => v.AttributeValues != null)
                .Select(v => new
