                    ConfigName = v.AttributeValues.FirstOrDefault(a => a.PredefinedAttributeValue?.ProductAttribute?.AttributeName.ToLower().Contains("dung lượng") == true || a.PredefinedAttributeValue?.ProductAttribute?.AttributeName.ToLower().Contains("rom") == true)?.PredefinedAttributeValue?.Value
                }).Where(x => !string.IsNullOrEmpty(x.ConfigName)).GroupBy(x => x.ConfigName).ToList();

                if (configGroups != null && configGroups.Any())
                {
                    foreach (var group in configGroups)
                    {
                        var info = GetBestVariantInfo(group.Select(g => g.Variant));
                        if (info.BestVariant == null) continue;

                        decimal basePrice = info.BestVariant.Price;
                        int discount = info.Discount;
                        bool isSale = discount > 0;
                        decimal salePrice = info.SalePrice;
                        string cardTitle = $"{item.ProductName} {group.Key}";
                        string imgUrl = !string.IsNullOrEmpty(info.BestVariant.ImageUrl) ? info.BestVariant.ImageUrl : item.ThumbnailUrl;

                        RenderProductCard(item, cardTitle, imgUrl, basePrice, salePrice, isSale, discount, "", "", "", "border-0", info.BestVariant.VariantId);
                    }
                }
                else
                {
                    var info = GetBestVariantInfo(item.ProductVariants);
                    decimal basePrice = info.BestVariant?.Price ?? 0;
                    int discount = info.Discount;
                    bool isSale = discount > 0;
                    decimal salePrice = info.SalePrice;
                    bool hasManyPrices = item.ProductVariants != null && item.ProductVariants.Select(v => v.Price).Distinct().Count() > 1;
                    string prefix = hasManyPrices ? "Giá từ: " : "";
                    int vId = info.BestVariant?.VariantId ?? 0;

                    RenderProductCard(item, item.ProductName, item.ThumbnailUrl, basePrice, salePrice, isSale, discount, prefix, "", "", "border-0", vId);
                }
            }
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2 mt-5">
        <h3 class="fw-bold text-uppercase text-danger m-0">Sản phẩm Bán Chạy</h3>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary top-slider-btn shadow-sm" onclick="scrollCarousel('bestSellersCarousel', -1)">❮</button>
            <button class="btn btn-outline-secondary top-slider-btn shadow-sm" onclick="scrollCarousel('bestSellersCarousel', 1)">❯</button>
        </div>
    </div>
    <div>
        <div class="product-carousel" id="bestSellersCarousel">
            @foreach (DoAnTotNghiep.Models.Product item in ViewBag.BestSellers)
            {
                var configGroups = item.ProductVariants?.Where(v => v.AttributeValues != null)
                .Select(v => new
                {
                    Variant = v,
                    ConfigName = v.AttributeValues.FirstOrDefault(a => a.PredefinedAttributeValue?.ProductAttribute?.AttributeName.ToLower().Contains("dung lượng") == true || a.PredefinedAttributeValue?.ProductAttribute?.AttributeName.ToLower().Contains("rom") == true)?.PredefinedAttributeValue?.Value
                }).Where(x => !string.IsNullOrEmpty(x.ConfigName)).GroupBy(x => x.ConfigName).ToList();

                if (configGroups != null && configGroups.Any())
                {
                    foreach (var group in configGroups)
                    {
                        var info = GetBestVariantInfo(group.Select(g => g.Variant));
                        if (info.BestVariant == null) continue;

                        decimal basePrice = info.BestVariant.Price;
                        int discount = info.Discount;
                        bool isSale = discount > 0;
                        decimal salePrice = info.SalePrice;
                        string cardTitle = $"{item.ProductName} {group.Key}";
                        string imgUrl = !string.IsNullOrEmpty(info.BestVariant.ImageUrl) ? info.BestVariant.ImageUrl : item.ThumbnailUrl;

                        RenderProductCard(item, cardTitle, imgUrl, basePrice, salePrice, isSale, discount, "", "HOT", "bg-danger text-white", "border-0", info.BestVariant.VariantId);
                    }
                }
                else
                {
                    var info = GetBestVariantInfo(item.ProductVariants);
                    decimal basePrice = info.BestVariant?.Price ?? 0;
                    int discount = info.Discount;
                    bool isSale = discount > 0;
                    decimal salePrice = info.SalePrice;
                    bool hasManyPrices = item.ProductVariants != null && item.ProductVariants.Select(v => v.Price).Distinct().Count() > 1;
                    string prefix = hasManyPrices ? "Giá từ: " : "";
                    int vId = info.BestVariant?.VariantId ?? 0;

                    RenderProductCard(item, item.ProductName, item.ThumbnailUrl, basePrice, salePrice, isSale, discount, prefix, "HOT", "bg-danger text-white", "border-0", vId);
                }
            }
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2 mt-5">
        <div class="d-flex align-items-center gap-3">
            <h3 class="fw-bold text-uppercase text-primary m-0">Tin tức mới nhất</h3>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary top-slider-btn shadow-sm" onclick="scrollCarousel('newsCarousel', -1)">❮</button>
            <button class="btn btn-outline-primary top-slider-btn shadow-sm" onclick="scrollCarousel('newsCarousel', 1)">❯</button>
        </div>
    </div>
    <div>
        <div class="product-carousel" id="newsCarousel">
            @if (ViewBag.RecentNews != null)
            {
                foreach (var item in ViewBag.RecentNews)
                {
                    <div class="carousel-item-card px-2">
                        <div class="card h-100 border-1 rounded-3 p-3 text-center shadow-sm news-card-hover bg-white">
                            <a href="/News/Details/@item.NewsId" class="text-decoration-none">
                                <div class="mb-3 d-flex align-items-center justify-content-center overflow-hidden" style="height: 150px;">
                                    <img src="@item.ImageUrl" alt="@item.Title" class="img-fluid rounded" style="max-height: 100%; object-fit: cover;">
                                </div>
                            </a>
                            <a href="/News/Details/@item.NewsId" class="text-decoration-none text-dark">
                                <h6 class="fw-bold mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; min-height: 40px;">
                                    @item.Title
                                </h6>
                            </a>
                            <div class="text-danger fw-bold mb-3 small">
                                @item.CreatedDate.ToString("dd/MM/yyyy")
                            </div>
                            <div class="mt-auto">
                                <a href="/News/Details/@item.NewsId" class="btn btn-outline-primary w-100 fw-bold">Xem chi tiết</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<div class="modal fade" id="loginRequireFavModal" tabindex="-1" aria-labelledby="loginRequireFavModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-warning text-dark rounded-top-4 border-0">
                <h5 class="modal-title fw-bold" id="loginRequireFavModalLabel">
                    <i class="fas fa-lock me-2"></i>Yêu cầu đăng nhập
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <div class="text-warning mb-3">
                    <i class="fas fa-user-circle" style="font-size: 3rem;"></i>
                </div>
                <p class="fs-5 mb-0 fw-bold text-dark">Vui lòng đăng nhập!</p>
                <p class="text-muted small mt-2">Bạn cần đăng nhập để có thể thêm sản phẩm vào danh sách yêu thích.</p>
            </div>
            <div class="modal-footer border-0 p-4 pt-0 justify-content-center gap-2">
                <button type="button" class="btn btn-light fw-bold px-4 rounded-pill" data-bs-dismiss="modal">Hủy bỏ</button>
                <a asp-area="" asp-controller="Account" asp-action="Login" class="btn btn-primary fw-bold px-4 rounded-pill shadow-sm">
                    Đăng nhập
                </a>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1055">
    <div id="favoriteToast" class="toast align-items-center text-white border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body fw-bold fs-6" id="favoriteToastMessage">
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 25px rgba(0,0,0,0.1) !important;
        }

    .hover-primary:hover {
        color: #0d6efd !important;
    }

    .product-carousel {
        display: flex;
        overflow-x: auto;
        scroll-behavior: smooth;
        padding-top: 15px;
        padding-bottom: 25px;
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

        .product-carousel::-webkit-scrollbar {
            display: none;
        }

    .carousel-item-card {
        flex: 0 0 auto;
        width: 25%;
    }

    .top-slider-btn {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        transition: all 0.3s ease;
        background-color: white;
    }

        .top-slider-btn:hover {
            background-color: #0d6efd;
            color: white;
            border-color: #0d6efd;
        }

    @@media (max-width: 992px) {
        .carousel-item-card {
            width: 33.3333%;
        }
    }

    @@media (max-width: 768px) {
        .carousel-item-card {
            width: 50%;
        }
    }

    @@media (max-width: 576px) {
        .carousel-item-card {
            width: 100%;
        }
    }

    .news-card-hover {
        transition: all 0.3s ease-in-out;
        border-color: #dee2e6;
    }

        .news-card-hover:hover {
            border-color: #0d6efd !important;
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
            transform: translateY(-3px);
        }

    .heart-btn {
        transition: all 0.2s ease-in-out;
        color: #adb5bd;
        background-color: transparent;
    }

        .heart-btn:hover {
            background-color: #ffe6e6 !important;
        }

            .heart-btn:hover i {
                color: #dc3545;
                transform: scale(1.1);
            }

        .heart-btn.liked i {
            font-weight: 900;
            color: #dc3545;
        }
</style>

@section Scripts {
    <script>
        function scrollCarousel(carouselId, direction) {
            const container = document.getElementById(carouselId);
            if(container) {
                const cardWidth = container.querySelector('.carousel-item-card').offsetWidth;
                container.scrollBy({ left: direction * cardWidth, behavior: 'smooth' });
            }
        }

        // ĐÃ SỬA BƯỚC 3: Cập nhật hàm toggleFavorite để bật Modal khi chưa đăng nhập
        function toggleFavorite(btnElement, productId) {
            fetch('/Product/ToggleFavorite?productId=' + productId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success === false && data.message === "require_login") {
                    let loginModalEl = document.getElementById('loginRequireModal') || document.getElementById('loginRequireFavModal');
                    if (loginModalEl) {
                        let loginModal = new bootstrap.Modal(loginModalEl);
                        loginModal.show();
                    } else {
                        window.location.href = "/Account/Login";
                    }
                    return;
                }

                if (data.success === true) {
                    let icon = btnElement.querySelector('i');
                    let toastEl = document.getElementById('favoriteToast');
                    let toastMsg = document.getElementById('favoriteToastMessage');

                    if (data.isFavorite) {
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                        btnElement.classList.add('liked');

                        toastMsg.innerHTML = '<i class="fas fa-check-circle me-2 fs-5"></i>Đã thêm vào danh sách yêu thích!';
                        toastEl.className = 'toast align-items-center text-white bg-success border-0 shadow-lg';
                    } else {
                        icon.classList.remove('fas');
                        icon.classList.add('far');
                        btnElement.classList.remove('liked');

                        toastMsg.innerHTML = '<i class="fas fa-info-circle me-2 fs-5"></i>Đã bỏ khỏi danh sách yêu thích!';
                        toastEl.className = 'toast align-items-center text-white bg-secondary border-0 shadow-lg';
                    }

                    let toast = new bootstrap.Toast(toastEl, { delay: 3000 });
                    toast.show();
                }
            })
            .catch(error => console.error('Error:', error));
        }
    </script>
}