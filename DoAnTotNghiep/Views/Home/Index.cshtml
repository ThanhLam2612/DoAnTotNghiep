@{
    ViewData["Title"] = "Trang chủ - Cửa hàng điện thoại";
}
<div class="container mb-5">
    <div id="mainSlider" class="carousel slide shadow-lg" data-bs-ride="carousel" style="border-radius: 15px; overflow: hidden;">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#mainSlider" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#mainSlider" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#mainSlider" data-bs-slide-to="2"></button>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item active" data-bs-interval="4000">
                <img src="~/images/slide/banner1.png" class="d-block w-100" alt="Khuyến mãi mùa hè" style="height: 450px; object-fit: cover;">
                <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                    <h2 class="fw-bold text-warning">SIÊU SALE MÙA HÈ</h2>
                    <p class="fs-5">Giảm giá lên đến 50% cho tất cả các dòng Smartphone mới nhất.</p>
                </div>
            </div>
            <div class="carousel-item" data-bs-interval="4000">
                <img src="~/images/slide/banner2.png" class="d-block w-100" alt="Hàng mới về" style="height: 450px; object-fit: cover;">
                <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                    <h2 class="fw-bold text-info">HÀNG MỚI VỀ</h2>
                    <p class="fs-5">Khám phá ngay bộ sưu tập công nghệ đỉnh cao năm nay.</p>
                </div>
            </div>
            <div class="carousel-item" data-bs-interval="4000">
                <img src="~/images/slide/banner3.png" class="d-block w-100" alt="Giao hàng hỏa tốc" style="height: 450px; object-fit: cover;">
                <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                    <h2 class="fw-bold text-success">GIAO HÀNG HỎA TỐC</h2>
                    <p class="fs-5">Nhận hàng tận tay chỉ trong vòng 2 giờ tại khu vực nội thành.</p>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#mainSlider" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Trước</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#mainSlider" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Sau</span>
        </button>
    </div>
</div>
<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2 mt-5">
        <h3 class="fw-bold text-uppercase text-primary m-0">Sản phẩm mới về</h3>
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary top-slider-btn shadow-sm" onclick="scrollCarousel('newProductsCarousel', -1)">❮</button>
                <button class="btn btn-outline-secondary top-slider-btn shadow-sm" onclick="scrollCarousel('newProductsCarousel', 1)">❯</button>
            </div>
        </div>
    </div>
    <div>
        <div class="product-carousel" id="newProductsCarousel">
            @foreach (var item in ViewBag.NewProducts)
            {
                <div class="carousel-item-card px-2">
                    <div class="card h-100 shadow-sm border-0 product-card transition-hover">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId">
                            <img src="@item.ThumbnailUrl" class="card-img-top p-3" alt="@item.ProductName" style="height: 220px; object-fit: contain;">
                        </a>
                        <div class="card-body d-flex flex-column text-center">
                            <h6 class="card-title fw-bold mb-3" style="height: 40px; overflow: hidden;">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="text-dark text-decoration-none">
                                    @item.ProductName
                                </a>
                            </h6>
                            <div class="mt-auto">
                                <p class="text-danger fw-bold fs-5 mb-3">@item.BasePrice.ToString("#,##0") đ</p>
                                <form asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.ProductId" method="post">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn btn-outline-primary w-100 fw-bold">
                                        🛒 Thêm giỏ hàng
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2 mt-5">
        <h3 class="fw-bold text-uppercase text-danger m-0">Top Bán Chạy</h3>
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary top-slider-btn shadow-sm" onclick="scrollCarousel('bestSellersCarousel', -1)">❮</button>
                <button class="btn btn-outline-secondary top-slider-btn shadow-sm" onclick="scrollCarousel('bestSellersCarousel', 1)">❯</button>
            </div>
        </div>
    </div>
    <div>
        <div class="product-carousel" id="bestSellersCarousel">
            @foreach (var item in ViewBag.BestSellers)
            {
                <div class="carousel-item-card px-2">
                    <div class="card h-100 shadow-sm border-0 product-card transition-hover">
                        <div class="position-absolute top-0 start-0 bg-danger text-white fw-bold px-2 py-1 m-2 rounded">HOT</div>
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId">
                            <img src="@item.ThumbnailUrl" class="card-img-top p-3" alt="@item.ProductName" style="height: 220px; object-fit: contain;">
                        </a>
                        <div class="card-body d-flex flex-column text-center">
                            <h6 class="card-title fw-bold mb-3" style="height: 40px; overflow: hidden;">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="text-dark text-decoration-none">
                                    @item.ProductName
                                </a>
                            </h6>
                            <div class="mt-auto">
                                <p class="text-danger fw-bold fs-5 mb-3">@item.BasePrice.ToString("#,##0") đ</p>
                                <form asp-controller="Cart" asp-action="BuyNow" asp-route-id="@item.ProductId" method="post">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn btn-danger w-100 fw-bold shadow-sm">
                                        Mua ngay
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    <div class="d-flex justify-content-between align-items-end mb-4 border-bottom pb-2 mt-5">
        <h3 class="fw-bold text-uppercase text-dark m-0">📰 Tin tức mới nhất</h3>
        <a asp-controller="News" asp-action="Index" class="text-decoration-none fw-bold">Đọc thêm tin ➔</a>
    </div>
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
        @foreach (var news in ViewBag.RecentNews)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 transition-hover">
                    <a asp-controller="News" asp-action="Details" asp-route-id="@news.NewsId">
                        <img src="@news.ImageUrl" class="card-img-top" alt="..." style="height: 200px; object-fit: cover;">
                    </a>
                    <div class="card-body">
                        <small class="text-muted mb-2 d-block">📅 @news.CreatedDate.ToString("dd/MM/yyyy")</small>
                        <h5 class="card-title fw-bold mb-3">
                            <a asp-controller="News" asp-action="Details" asp-route-id="@news.NewsId" class="text-dark text-decoration-none">
                                @news.Title
                            </a>
                        </h5>
                        <p class="card-text text-muted" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                            @news.ShortDescription
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
        .transition-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 25px rgba(0,0,0,0.1) !important;
        }
    .product-carousel {
        display: flex;
        overflow-x: auto;
        scroll-behavior: smooth;
        padding-top: 15px;
        padding-bottom: 25px;
        -ms-overflow-style: none; 
        scrollbar-width: none; 
    }
        .product-carousel::-webkit-scrollbar {
            display: none; 
        }
    .carousel-item-card {
        flex: 0 0 auto;
        width: 25%;
    }
    .top-slider-btn {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        transition: all 0.3s ease;
        background-color: white;
    }
        .top-slider-btn:hover {
            background-color: #0d6efd;
            color: white;
            border-color: #0d6efd;
        }
    @@media (max-width: 992px) {
        .carousel-item-card {
            width: 33.3333%;
        }
    }

    @@media (max-width: 768px) {
        .carousel-item-card {
            width: 50%;
        }
    }
    @@media (max-width: 576px) {
        .carousel-item-card {
            width: 100%;
        }
    }
</style>
@section Scripts {
    <script>
        function scrollCarousel(carouselId, direction) {
            const container = document.getElementById(carouselId);
            if(container) {
                const cardWidth = container.querySelector('.carousel-item-card').offsetWidth;
                container.scrollBy({
                    left: direction * cardWidth,
                    behavior: 'smooth'
                });
            }
        }
    </script>
}