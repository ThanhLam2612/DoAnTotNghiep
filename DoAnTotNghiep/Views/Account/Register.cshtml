@model DoAnTotNghiep.Models.AppUser
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0 fw-bold">TẠO TÀI KHOẢN MỚI</h4>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Register" method="post">

                        <div class="row mb-3">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label class="fw-bold mb-1">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="FullName" class="form-control form-control-lg" placeholder="" />
                                <span asp-validation-for="FullName" class="text-danger small fw-bold"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="fw-bold mb-1">Tên đăng nhập <span class="text-danger">*</span></label>
                                <input asp-for="Username" class="form-control form-control-lg" placeholder="Viết liền không dấu..." />
                                <span asp-validation-for="Username" class="text-danger small fw-bold"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label class="fw-bold mb-1">Số điện thoại <span class="text-danger">*</span></label>
                                <input asp-for="Phone" type="tel" class="form-control form-control-lg" placeholder="" />
                                <span asp-validation-for="Phone" class="text-danger small fw-bold"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="fw-bold mb-1">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" type="email" class="form-control form-control-lg" placeholder="" />
                                <span asp-validation-for="Email" class="text-danger small fw-bold"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold mb-1">Ngày sinh</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control form-control-lg" />
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label class="fw-bold mb-1">Mật khẩu <span class="text-danger">*</span></label>
                                <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="" />
                                <span asp-validation-for="Password" class="text-danger small fw-bold"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="fw-bold mb-1">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg" placeholder="" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small fw-bold"></span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">
                            HOÀN TẤT ĐĂNG KÝ
                        </button>

                        <div class="text-center mt-3">
                            Đã có tài khoản? <a asp-action="Login" class="text-decoration-none fw-bold text-danger">Đăng nhập tại đây</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}