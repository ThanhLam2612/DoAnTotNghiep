@{
    ViewData["Title"] = "Đăng nhập hệ thống";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success fw-bold text-center">@TempData["Success"]</div>
            }

            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0 fw-bold">🔐 ĐĂNG NHẬP</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Login" method="post">
                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                        <div asp-validation-summary="ModelOnly" class="text-danger fw-bold text-center mb-3"></div>

                        <div class="mb-3">
                            <label class="fw-bold mb-1">Tên đăng nhập</label>
                            <input type="text" name="username" class="form-control form-control-lg" required placeholder="Nhập username..." />
                        </div>

                        <div class="mb-4">
                            <label class="fw-bold mb-1">Mật khẩu</label>
                            <input type="password" name="password" class="form-control form-control-lg" required placeholder="Nhập mật khẩu..." />
                        </div>

                        <button type="submit" class="btn btn-dark btn-lg w-100 fw-bold shadow-sm">
                            ĐĂNG NHẬP
                        </button>

                        <div class="text-center mt-3">
                            Chưa có tài khoản? <a asp-action="Register" class="text-decoration-none fw-bold text-danger">Đăng ký ngay</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>