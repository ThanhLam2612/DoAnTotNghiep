
@model DoAnTotNghiep.Models.AppUser
@{
    ViewData["Title"] = "Cập nhật thông tin cá nhân";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-warning text-dark text-center py-3">
                    <h4 class="mb-0 fw-bold">✏️ SỬA THÔNG TIN CÁ NHÂN</h4>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="EditProfile" method="post">

                        <div class="mb-3">
                            <label class="fw-bold mb-1 text-muted">Tên đăng nhập (Không thể thay đổi)</label>
                            <input asp-for="Username" class="form-control form-control-lg bg-light" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold mb-1">Họ và tên <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control form-control-lg" required />
                            <span asp-validation-for="FullName" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold mb-1">Số điện thoại <span class="text-danger">*</span></label>
                            <input asp-for="Phone" type="tel" class="form-control form-control-lg" required />
                            <span asp-validation-for="Phone" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold mb-1">Email liên hệ <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control form-control-lg" required />
                            <span asp-validation-for="Email" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="mb-5">
                            <label class="fw-bold mb-1">Ngày sinh</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control form-control-lg" />
                        </div>

                        <div class="d-flex justify-content-between gap-3">
                            <a asp-action="Profile" class="btn btn-secondary btn-lg fw-bold w-50">
                                ❌ Hủy bỏ
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg fw-bold w-50 shadow-sm">
                                💾 LƯU THAY ĐỔI
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}