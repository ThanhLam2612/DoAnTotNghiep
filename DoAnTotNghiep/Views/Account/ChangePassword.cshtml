@model DoAnTotNghiep.Models.ChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-4 rounded-top-4">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-shield-lock"></i> Đổi mật khẩu</h4>
                </div>

                <div class="card-body p-5">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success fw-bold text-center">
                            @TempData["SuccessMessage"]
                        </div>
                    }

                    <p class="text-muted text-center mb-4">Vui lòng nhập mật khẩu hiện tại và mật khẩu mới để bảo mật tài khoản của bạn.</p>

                    <form asp-action="ChangePassword" method="post">

                        <div class="mb-4">
                            <label asp-for="OldPassword" class="form-label fw-bold">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                            <input asp-for="OldPassword" class="form-control form-control-lg bg-light" placeholder="Nhập mật khẩu đang sử dụng..." />
                            <span asp-validation-for="OldPassword" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="NewPassword" class="form-label fw-bold text-primary">Mật khẩu mới <span class="text-danger">*</span></label>
                            <input asp-for="NewPassword" class="form-control form-control-lg border-primary" placeholder="Tối thiểu 6 ký tự..." />
                            <span asp-validation-for="NewPassword" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmNewPassword" class="form-label fw-bold">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                            <input asp-for="ConfirmNewPassword" class="form-control form-control-lg" placeholder="Nhập lại mật khẩu mới..." />
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="d-grid mt-5">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">
                                💾 XÁC NHẬN ĐỔI MẬT KHẨU
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted fw-bold">
                    ⬅ Quay về trang chủ
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
