@model DoAnTotNghiep.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.OrderId;
}
<div class="container mt-4 mb-5">
    <a asp-action="Index" class="btn btn-secondary mb-3">⬅ Quay lại danh sách</a>
    <h3 class="fw-bold mb-4 text-primary">Chi tiết đơn hàng <span class="text-danger">#@Model.OrderId</span></h3>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success fw-bold text-center shadow-sm">✅ @TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger fw-bold text-center shadow-sm">❌ @TempData["Error"]</div>
    }
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-dark text-white fw-bold py-3 fs-5">📍 Thông tin nhận hàng</div>
                <div class="card-body fs-6 lh-lg">
                    <p><strong>Người nhận:</strong> @Model.CustomerName</p>
                    <p><strong>Điện thoại:</strong> @Model.Phone</p>
                    <p><strong>Địa chỉ:</strong> @Model.Address</p>
                    <p>
                        <strong>Trạng thái:</strong>
                        @if (Model.Status == 0)
                        {
                            <span class="text-warning fw-bold">⏳ Chờ duyệt</span>
                        }
                        else if (Model.Status == 1)
                        {
                            <span class="text-info fw-bold">🚚 Đang giao</span>
                        }
                        else if (Model.Status == 2)
                        {
                            <span class="text-success fw-bold">✅ Hoàn thành</span>
                        }
                        else
                        {
                            <span class="text-danger fw-bold">❌ Đã hủy</span>
                        }
                    </p>
                    @if (Model.Status == 0)
                    {
                        <hr class="my-3" />
                        <form asp-action="CancelOrder" asp-route-id="@Model.OrderId" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không? (Hành động này không thể hoàn tác)');">
                            <button type="submit" class="btn btn-outline-danger w-100 fw-bold shadow-sm">
                                ❌ HỦY ĐƠN HÀNG NÀY
                            </button>
                        </form>
                    }
                    else if (Model.Status == 1)
                    {
                        <hr class="my-3" />
                        <div class="alert alert-info text-center small fw-bold mb-0">
                            🚚 Đơn hàng đang trên đường giao đến bạn, không thể hủy.
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-dark fw-bold py-3 fs-5">🛍️ Sản phẩm đã mua</div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Tên sản phẩm</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in Model.OrderDetails)
                            {
                                var thanhTien = detail.Quantity * detail.Price;
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @if (detail.Product != null && !string.IsNullOrEmpty(detail.Product.ThumbnailUrl))
                                            {
                                                <img src="@detail.Product.ThumbnailUrl" style="width:50px; height:50px; object-fit:contain;" class="me-3 border rounded p-1" />
                                            }
                                            <span class="fw-bold">@detail.Product?.ProductName</span>
                                        </div>
                                    </td>
                                    <td class="text-center fw-bold">x @detail.Quantity</td>
                                    <td class="text-end text-muted">@detail.Price.ToString("#,##0") đ</td>
                                    <td class="text-end fw-bold text-danger">@thanhTien.ToString("#,##0") đ</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold fs-5">TỔNG TIỀN ĐƠN HÀNG:</td>
                                <td class="text-end text-danger fw-bold fs-4">@Model.TotalAmount.ToString("#,##0") đ</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>