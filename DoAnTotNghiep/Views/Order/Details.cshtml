@model DoAnTotNghiep.Models.Order
@using Microsoft.EntityFrameworkCore
@inject DoAnTotNghiep.Models.AppDbContext _context
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.OrderId;
}
<div class="container mt-4 mb-5">
    <a asp-action="Index" class="btn btn-secondary mb-3"><i class="fas fa-arrow-left me-1"></i> Quay lại danh sách</a>
    <h3 class="fw-bold mb-4 text-primary">Chi tiết đơn hàng <span class="text-danger">#@Model.OrderId</span></h3>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success fw-bold text-center shadow-sm">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger fw-bold text-center shadow-sm">@TempData["Error"]</div>
    }
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4 position-sticky" style="top: 20px;">
                <div class="card-header bg-dark text-white fw-bold py-3 fs-5">Thông tin nhận hàng</div>
                <div class="card-body fs-6 lh-lg">
                    <p><strong>Người nhận:</strong> @Model.CustomerName</p>
                    <p><strong>Điện thoại:</strong> @Model.Phone</p>
                    <p class="mb-2"><strong>Địa chỉ:</strong> @Model.Address</p>

                    <p class="mb-2">
                        <strong>Thanh toán:</strong>
                        @if (Model.PaymentMethod == "VNPAY")
                        {
                            <span class="badge bg-primary px-2 py-1 shadow-sm">
                                <i class="fas fa-credit-card me-1"></i> Đã thanh toán VNPAY
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary px-2 py-1 shadow-sm">
                                <i class="fas fa-truck me-1"></i> Nhận hàng (COD)
                            </span>
                        }
                    </p>

                    <p>
                        <strong>Trạng thái:</strong>
                        @if (Model.Status == 0)
                        {
                            <span class="text-warning fw-bold"><i class="fas fa-clock me-1"></i> Chờ duyệt</span>
                        }
                        else if (Model.Status == 1)
                        {
                            <span class="text-info fw-bold"><i class="fas fa-shipping-fast me-1"></i> Đang giao</span>
                        }
                        else if (Model.Status == 2)
                        {
                            <span class="text-success fw-bold"><i class="fas fa-check-circle me-1"></i> Hoàn thành</span>
                        }
                        else
                        {
                            <span class="text-danger fw-bold"><i class="fas fa-times-circle me-1"></i> Đã hủy</span>
                        }
                    </p>

                    @if (Model.Status == 0)
                    {
                        <hr class="my-3" />
                        <form asp-action="CancelOrder" asp-route-id="@Model.OrderId" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này không? (Hành động này không thể hoàn tác)');">
                            <button type="submit" class="btn btn-outline-danger w-100 fw-bold shadow-sm">
                                HỦY ĐƠN HÀNG NÀY
                            </button>
                        </form>
                    }
                    else if (Model.Status == 1)
                    {
                        <hr class="my-3" />
                        <div class="alert alert-info text-center small fw-bold mb-0">
                            Đơn hàng đang trên đường giao đến bạn, không thể hủy.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-dark fw-bold py-3 fs-5">Sản phẩm đã mua</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tên sản phẩm</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detail in Model.OrderDetails)
                                {
                                    var thanhTien = detail.Quantity * detail.Price;
                                    string finalImageUrl = detail.Product?.ThumbnailUrl;

                                    if (detail.ProductVariant != null)
                                    {
                                        if (!string.IsNullOrEmpty(detail.ProductVariant.ImageUrl))
                                        {
                                            finalImageUrl = detail.ProductVariant.ImageUrl;
                                        }
                                        else
                                        {
                                            var colorAttr = detail.ProductVariant.AttributeValues?.FirstOrDefault(a =>
                                            a.PredefinedAttributeValue != null &&
                                            a.PredefinedAttributeValue.ProductAttribute != null &&
                                            (a.PredefinedAttributeValue.ProductAttribute.AttributeName.ToLower().Contains("màu") ||
                                            a.PredefinedAttributeValue.ProductAttribute.AttributeName.ToLower().Contains("color")));

                                            if (colorAttr != null)
                                            {
                                                int colorId = colorAttr.PredefinedValueId;

                                                var siblingVariant = _context.ProductVariants
                                                .Include(v => v.AttributeValues)
                                                .FirstOrDefault(v => v.ProductId == detail.ProductId
                                                && v.VariantId != detail.VariantId
                                                && !string.IsNullOrEmpty(v.ImageUrl)
                                                && v.AttributeValues.Any(a => a.PredefinedValueId == colorId));

                                                if (siblingVariant != null)
                                                {
                                                    finalImageUrl = siblingVariant.ImageUrl;
                                                }
                                            }
                                        }
                                    }

                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                @if (!string.IsNullOrEmpty(finalImageUrl))
                                                {
                                                    <img src="@finalImageUrl" style="width:50px; height:50px; object-fit:contain;" class="me-3 border rounded shadow-sm p-1" />
                                                }

                                                <div>
                                                    <div class="fw-bold text-dark">@detail.Product?.ProductName</div>

                                                    @if (detail.ProductVariant != null && detail.ProductVariant.AttributeValues != null)
                                                    {
                                                        <div class="text-muted mt-1 d-flex flex-wrap align-items-center gap-1" style="font-size: 0.85rem;">
                                                            <i class="bi bi-tag-fill me-1 text-secondary"></i>
                                                            @{
                                                                var attrList = detail.ProductVariant.AttributeValues.ToList();
                                                                for (int i = 0; i < attrList.Count; i++)
                                                                {
                                                                    var av = attrList[i];
                                                                    var preDef = av.PredefinedAttributeValue;

                                                                    if (preDef != null && preDef.ProductAttribute != null)
                                                                    {
                                                                        bool isColor = preDef.ProductAttribute.AttributeName.ToLower().Contains("màu") ||
                                                                        preDef.ProductAttribute.AttributeName.ToLower().Contains("color");

                                                                        <span class="d-inline-flex align-items-center">
                                                                            @if (isColor && !string.IsNullOrEmpty(preDef.ColorHex))
                                                                            {
                                                                                <span>@preDef.ProductAttribute.AttributeName:</span>
                                                                                <span class="rounded-circle border border-secondary ms-1 shadow-sm"
                                                                                      style="width: 12px; height: 12px; background-color: @preDef.ColorHex; display: inline-block;"></span>
                                                                            }
                                                                            else
                                                                            {
                                                                                <span>@preDef.ProductAttribute.AttributeName: @preDef.Value</span>
                                                                            }
                                                                        </span>

                                                                        if (i < attrList.Count - 1)
                                                                        {
                                                                            <span class="mx-1">|</span>
                                                                        }
                                                                    }
                                                                }
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center fw-bold">x @detail.Quantity</td>
                                        <td class="text-end text-muted">@detail.Price.ToString("#,##0") đ</td>
                                        <td class="text-end fw-bold text-danger">@thanhTien.ToString("#,##0") đ</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="text-end fw-bold fs-5">TỔNG TIỀN ĐƠN HÀNG:</td>
                                    <td class="text-end text-danger fw-bold fs-4">@Model.TotalAmount.ToString("#,##0") đ</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>