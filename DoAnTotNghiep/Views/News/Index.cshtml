@model IEnumerable<DoAnTotNghiep.Models.News>
@{
    ViewData["Title"] = "Tin tức công nghệ";
}
<div class="container mt-4 mb-5">
    <h2 class="fw-bold text-center mb-4 text-uppercase">📰 TIN TỨC & BÀI VIẾT</h2>
    <hr class="w-25 mx-auto text-primary mb-5" style="height: 3px; border-radius: 5px;">
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 transition-hover">
                    <a asp-action="Details" asp-route-id="@item.NewsId">
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 220px; object-fit: cover;">
                    </a>
                    <div class="card-body d-flex flex-column">
                        <small class="text-muted mb-2">📅 @item.CreatedDate.ToString("dd/MM/yyyy")</small>
                        <h5 class="card-title fw-bold">
                            <a asp-action="Details" asp-route-id="@item.NewsId" class="text-decoration-none text-dark">
                                @item.Title
                            </a>
                        </h5>
                        <p class="card-text text-muted mb-4" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                            @item.ShortDescription
                        </p>
                        <div class="mt-auto">
                            <a asp-action="Details" asp-route-id="@item.NewsId" class="btn btn-outline-primary fw-bold w-100">
                                Đọc tiếp ➔
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
<style>
    .transition-hover { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .transition-hover:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
</style>