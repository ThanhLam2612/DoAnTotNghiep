@model IEnumerable<DoAnTotNghiep.Models.Product>

@{
    ViewData["Title"] = "Tất cả sản phẩm";
    var promoDict = ViewBag.PromoDict as Dictionary<int, int>;
}

<div class="container mt-4 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Sản phẩm</li>
        </ol>
    </nav>

    @if (!string.IsNullOrEmpty(ViewBag.SearchKeyword))
    {
        <h3 class="fw-bold text-center mb-4">
            🔍 Kết quả tìm kiếm cho: <span class="text-danger">"@ViewBag.SearchKeyword"</span>
        </h3>
        <p class="text-center text-muted mb-4">Tìm thấy <strong>@Model.Count()</strong> sản phẩm phù hợp.</p>
    }
    else
    {
        <h2 class="fw-bold text-center mb-4 text-uppercase">Tất cả sản phẩm</h2>
    }

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm product-card transition-hover position-relative">
                    @{
                        bool isSale = promoDict != null && promoDict.ContainsKey(item.ProductId);
                        int discount = isSale ? promoDict[item.ProductId] : 0;
                        decimal basePrice = (decimal)item.BasePrice;
                        decimal salePrice = basePrice - (basePrice * discount / 100);
                    }

                    @if (isSale)
                    {
                        <div class="position-absolute top-0 end-0 bg-danger text-white fw-bold px-2 py-1 m-2 rounded-circle shadow" style="z-index: 2;">
                            -@discount%
                        </div>
                    }

                    <a asp-action="Details" asp-route-id="@item.ProductId">
                        <img src="@item.ThumbnailUrl" class="card-img-top p-3" alt="@item.ProductName" style="height: 250px; object-fit: contain;">
                    </a>

                    <div class="card-body d-flex flex-column text-center">
                        <h5 class="card-title fw-bold">
                            <a asp-action="Details" asp-route-id="@item.ProductId" class="text-decoration-none text-dark">@item.ProductName</a>
                        </h5>

                        <div class="mb-3 mt-auto">
                            @if (isSale)
                            {
                                <span class="text-muted text-decoration-line-through me-2" style="font-size: 0.9rem;">
                                    @basePrice.ToString("#,##0") đ
                                </span>
                                <span class="text-danger fw-bold fs-5">
                                    @salePrice.ToString("#,##0") đ
                                </span>
                            }
                            else
                            {
                                <span class="text-danger fw-bold fs-5">
                                    @basePrice.ToString("#,##0") đ
                                </span>
                            }
                        </div>

                        <div class="mt-auto d-grid gap-2">
                            <a asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-outline-primary fw-bold">👁️ Xem chi tiết</a>
                            <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.ProductId" class="btn btn-primary fw-bold">🛒 Thêm vào giỏ</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-5">
        <ul class="pagination justify-content-center shadow-sm">

            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link fw-bold px-3" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage - 1)"
                   asp-route-categoryId="@ViewBag.CategoryId"
                   asp-route-searchString="@ViewBag.SearchKeyword">❮ Trước</a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link fw-bold px-3" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-categoryId="@ViewBag.CategoryId"
                       asp-route-searchString="@ViewBag.SearchKeyword">@i</a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link fw-bold px-3" asp-action="Index"
                   asp-route-page="@(ViewBag.CurrentPage + 1)"
                   asp-route-categoryId="@ViewBag.CategoryId"
                   asp-route-searchString="@ViewBag.SearchKeyword">Sau ❯</a>
            </li>

        </ul>
    </nav>
}
<style>
    .product-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
        }
</style>