<style>
    .product-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .product-card:hover { transform: translateY(-8px); box-shadow: 0 15px 25px rgba(0,0,0,0.15) !important; }
    .attr-btn { transition: all 0.2s ease; user-select: none; }
    .attr-btn:hover { border-color: #0d6efd; color: #0d6efd; }
    .attr-btn.selected { border-color: #0d6efd !important; background-color: #f8fbff !important; color: #0d6efd; border-width: 2px; font-weight: bold; }
    .cursor-pointer { cursor: pointer; }

    .product-carousel {
        display: flex;
        overflow-x: auto;
        scroll-behavior: smooth;
        padding-top: 15px;
        padding-bottom: 25px;
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    .product-carousel::-webkit-scrollbar { display: none; }
    .carousel-item-card { flex: 0 0 auto; width: 25%; }
    .top-slider-btn {
        width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
        font-weight: bold; transition: all 0.3s ease; background-color: white;
    }
    .top-slider-btn:hover { background-color: #0d6efd; color: white; border-color: #0d6efd; }
    
    @@media (max-width: 992px) { .carousel-item-card { width: 33.3333%; } }
    @@media (max-width: 768px) { .carousel-item-card { width: 50%; } }
    @@media (max-width: 576px) { .carousel-item-card { width: 100%; } }

    /* CSS cho trái tim của sản phẩm tương tự */
    .heart-btn { transition: all 0.2s ease-in-out; }
    .heart-btn:hover i { color: #dc3545; transform: scale(1.1); }
    .heart-btn.liked i { font-weight: 900; color: #dc3545; }

    /* ĐÃ SỬA: CSS CHO NÚT THẢ TIM SẢN PHẨM CHÍNH (Tròn, viền xám, hover hồng) */
    .main-heart-btn { transition: all 0.2s ease-in-out; outline: none; background-color: white; }
    .main-heart-btn i { color: #adb5bd; transition: all 0.2s; }
    .main-heart-btn:hover { background-color: #ffe6e6 !important; border-color: #ffb3b3 !important; }
    .main-heart-btn:hover i { color: #dc3545; transform: scale(1.1); }
    .main-heart-btn.liked { background-color: #fff5f5; border-color: #ffb3b3 !important; }
    .main-heart-btn.liked i { font-weight: 900; color: #dc3545; }
</style>

@section Scripts {
    @{
        var variantData = Model.ProductVariants?
            .Where(v => v.StockQuantity > 0)
            .Select(v => {
                var activePv = variantPromos.OrderByDescending(p => p.DiscountPercent).FirstOrDefault(p => p.VariantId == v.VariantId);
                int varDiscount = activePv != null ? activePv.DiscountPercent : 0;
                string promoTitle = activePv != null ? activePv.Promotion.PromotionName : "";
                
                var galleryImgs = variantGalleries.Where(g => g.VariantId == v.VariantId).Select(g => g.ImageUrl).ToList();
                if (!string.IsNullOrEmpty(v.ImageUrl) && !galleryImgs.Contains(v.ImageUrl)) {
                    galleryImgs.Insert(0, v.ImageUrl);
                }

                return new {
                    id = v.VariantId,
                    price = v.Price,
                    discount = varDiscount, 
                    promoName = promoTitle,
                    stock = v.StockQuantity,
                    image = v.ImageUrl, 
                    gallery = galleryImgs,
                    attributes = v.AttributeValues
                        .Where(a => a.PredefinedAttributeValue != null && a.PredefinedAttributeValue.ProductAttribute != null)
                        .ToDictionary(
                            a => a.PredefinedAttributeValue.ProductAttribute.AttributeName, 
                            a => a.PredefinedAttributeValue.Value
                        )
                };
            }).ToList();
    }
    <script>
        const variants = @Html.Raw(Json.Serialize(variantData));
        let selectedAttributes = {};

        function showToastMessage(type, message) {
            let toastEl = document.getElementById('favoriteToast');
            let toastMsg = document.getElementById('favoriteToastMessage');
            let closeBtn = document.getElementById('toastCloseBtn');
            
            if (type === 'success') {
                toastMsg.innerHTML = '<i class="fas fa-check-circle me-2 fs-5"></i>' + message;
                toastEl.className = 'toast align-items-center text-white bg-success border-0 shadow-lg';
                closeBtn.classList.add('btn-close-white');
            } else if (type === 'warning') {
                toastMsg.innerHTML = '<i class="fas fa-exclamation-triangle me-2 fs-5"></i>' + message;
                toastEl.className = 'toast align-items-center text-dark bg-warning border-0 shadow-lg';
                closeBtn.classList.remove('btn-close-white');
            } else if (type === 'danger') {
                toastMsg.innerHTML = '<i class="fas fa-exclamation-circle me-2 fs-5"></i>' + message;
                toastEl.className = 'toast align-items-center text-white bg-danger border-0 shadow-lg';
                closeBtn.classList.add('btn-close-white');
            } else {
                toastMsg.innerHTML = '<i class="fas fa-info-circle me-2 fs-5"></i>' + message;
                toastEl.className = 'toast align-items-center text-white bg-secondary border-0 shadow-lg';
                closeBtn.classList.add('btn-close-white');
            }
            
            let toast = new bootstrap.Toast(toastEl, { delay: 4000 });
            toast.show();
        }

        function selectAttribute(element, attrName, attrValue) {
            let groupDiv = element.closest('.attribute-group');
            groupDiv.querySelectorAll('.attr-btn').forEach(btn => btn.classList.remove('selected'));
            element.classList.add('selected');
            selectedAttributes[attrName] = attrValue;

            let attrNameLower = attrName.toLowerCase();
            let isColorAttribute = attrNameLower.includes('màu') || attrNameLower.includes('color');

            if (isColorAttribute) {
                let tempImage = null;
                for (let variant of variants) {
                    if (variant.attributes[attrName] === attrValue && variant.image && variant.image.trim() !== '') {
                        tempImage = variant.image;
                        break;
                    }
                }
                if (tempImage) {
                    let mainImg = document.getElementById('mainProductImage');
                    if (mainImg && !mainImg.src.includes(tempImage)) {
                        mainImg.style.transition = "opacity 0.15s ease-in-out"; 
                        mainImg.style.opacity = 0.5; 
                        setTimeout(() => {
                            mainImg.src = tempImage;
                            mainImg.style.opacity = 1;
                        }, 150);
                    }
                }
            }

            let totalGroups = document.querySelectorAll('.attribute-group').length;
            if (Object.keys(selectedAttributes).length === totalGroups) {
                checkVariantMatch();
            }
        }

        function checkVariantMatch() {
            let matchedVariant = null;

            for (let variant of variants) {
                let isMatch = true;
                for (let key in selectedAttributes) {
                    if (variant.attributes[key] !== selectedAttributes[key]) {
                        isMatch = false;
                        break;
                    }
                }
                if (isMatch) {
                    matchedVariant = variant;
                    break;
                }
            }

            let btnAdd = document.getElementById('btnAddToCart');
            let btnBuyNow = document.getElementById('btnBuyNow');
            let priceDisplay = document.getElementById('displayPrice');
            let originalPriceDisplay = document.getElementById('originalPrice');
            let stockStatus = document.getElementById('stockStatus');
            let badge = document.getElementById('discountBadge');

            if (!matchedVariant) {
                document.getElementById('selectedVariantId').value = "";
                document.getElementById('reviewVariantId').value = ""; 
                
                stockStatus.innerHTML = `<i class="bi bi-clock-history text-primary me-1"></i> <span class="text-primary fw-bold">Sắp về hàng (Cấu hình này hiện chưa khả dụng)</span>`;
                if(priceDisplay) priceDisplay.innerHTML = "Liên hệ";
                if(originalPriceDisplay) originalPriceDisplay.classList.add('d-none');
                if(badge) badge.classList.add('d-none');
                if(btnAdd) btnAdd.disabled = true;
                if(btnBuyNow) btnBuyNow.disabled = true;
                return; 
            }

            if (matchedVariant && matchedVariant.stock <= 0) {
                showToastMessage('warning', 'Phiên bản này đã hết hàng, đang chuyển sang phiên bản còn hàng...');

                let alternative = variants.find(v => v.stock > 0);
                if (alternative) {
                    setTimeout(() => {
                        for (let attrName in alternative.attributes) {
                            let attrVal = alternative.attributes[attrName];
                            let btn = document.querySelector(`.attribute-group[data-attr-name="${attrName}"] .variant-option[onclick*="'${attrVal}'"]`);
                            if (btn) btn.click();
                        }
                    }, 1500); 
                }
                return;
            }

            document.getElementById('selectedVariantId').value = matchedVariant.id;
            document.getElementById('reviewVariantId').value = matchedVariant.id; 
            
            let finalPrice = matchedVariant.price;
            let currentVariantDiscount = matchedVariant.discount || 0; 

            if (currentVariantDiscount > 0) {
                finalPrice = finalPrice - (finalPrice * currentVariantDiscount / 100);
                if(originalPriceDisplay) {
                    originalPriceDisplay.innerHTML = new Intl.NumberFormat('vi-VN').format(matchedVariant.price) + " đ";
                    originalPriceDisplay.classList.remove('d-none');
                }
                if(badge) {
                    badge.innerHTML = `Giảm ${currentVariantDiscount}% (${matchedVariant.promoName})`;
                    badge.classList.remove('d-none');
                }
            } else {
                if(originalPriceDisplay) originalPriceDisplay.classList.add('d-none');
                if(badge) badge.classList.add('d-none');
            }

            if(priceDisplay) priceDisplay.innerHTML = new Intl.NumberFormat('vi-VN').format(finalPrice) + " đ";
            stockStatus.innerHTML = `<i class="bi bi-check-circle-fill text-success me-1"></i> <span class="text-success">Sẵn sàng giao hàng (Còn ${matchedVariant.stock} sản phẩm)</span>`;
            
            let qtyInput = document.getElementById('quantityInput');
            qtyInput.setAttribute('max', matchedVariant.stock); 
            if (parseInt(qtyInput.value) > matchedVariant.stock) qtyInput.value = matchedVariant.stock; 
            
            if(btnAdd) btnAdd.disabled = false;
            if(btnBuyNow) btnBuyNow.disabled = false;
            
            if (matchedVariant.image) {
                let mainImg = document.getElementById('mainProductImage');
                if (mainImg) mainImg.src = matchedVariant.image;
            }
        }

        function changeQty(amount) {
            let input = document.getElementById('quantityInput');
            let currentVal = parseInt(input.value);
            let maxVal = parseInt(input.getAttribute('max')) || 1000; 
            let newVal = currentVal + amount;
            
            if (newVal > maxVal) {
                showToastMessage('warning', 'Rất tiếc, phiên bản này chỉ còn ' + maxVal + ' sản phẩm trong kho!');
                input.value = maxVal;
            } else if (newVal < 1) {
                showToastMessage('warning', 'Số lượng mua tối thiểu phải là 1!');
                input.value = 1;
            } else {
                input.value = newVal;
            }
        }
        
        function changeMainImage(element, newSrc) {
            let mainImg = document.getElementById('mainProductImage');
            if (mainImg.src.includes(newSrc)) return;
            document.querySelectorAll('.variant-thumb').forEach(thumb => {
                thumb.classList.add('opacity-50');
                thumb.style.borderColor = '#dee2e6'; 
            });
            element.classList.remove('opacity-50');
            element.style.borderColor = '#0d6efd';
            mainImg.style.opacity = 0.5;
            setTimeout(() => {
                mainImg.src = newSrc;
                mainImg.style.opacity = 1;
            }, 150);
        }

        function scrollCarousel(carouselId, direction) {
            const container = document.getElementById(carouselId);
            if(container) {
                const cardWidth = container.querySelector('.carousel-item-card').offsetWidth;
                container.scrollBy({ left: direction * cardWidth, behavior: 'smooth' });
            }
        }

        function toggleReviewLike(btnElement, reviewId) {
            let icon = btnElement.querySelector('i');
            let originalClass = icon.className;
            icon.className = 'fas fa-spinner fa-spin me-1';

            fetch(`/Product/ToggleReviewLike?reviewId=${reviewId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success === false && data.message === "require_login") {
                    let loginModalEl = document.getElementById('loginRequireModal') || document.getElementById('loginRequireFavModal');
                    if (loginModalEl) {
                        new bootstrap.Modal(loginModalEl).show();
                    } else {
                        window.location.href = "/Account/Login";
                    }
                    icon.className = originalClass;
                    return;
                }

                if (data.success) {
                    document.getElementById(`like-count-${reviewId}`).innerText = data.newCount;
                    
                    if (data.isLiked) {
                        btnElement.classList.remove('text-secondary');
                        btnElement.classList.add('text-primary');
                        icon.className = 'fas fa-thumbs-up me-1 text-primary';
                    } else {
                        btnElement.classList.remove('text-primary');
                        btnElement.classList.add('text-secondary');
                        icon.className = 'far fa-thumbs-up me-1';
                    }
                } else {
                    showToastMessage('danger', data.message || "Lỗi hệ thống!");
                    icon.className = originalClass;
                }
            })
            .catch(error => {
                console.error("Error:", error);
                icon.className = originalClass;
            });
        }

        function openEditReviewModal(reviewId, currentRating, currentComment) {
            document.getElementById('editReviewId').value = reviewId;
            document.getElementById('editComment').value = currentComment;
            document.getElementById('editRatingValue').value = currentRating;

            $('.edit-star-sel').each(function () {
                if ($(this).data('val') <= currentRating) {
                    $(this).removeClass('far').addClass('fas');
                } else {
                    $(this).removeClass('fas').addClass('far');
                }
            });

            var editModal = new bootstrap.Modal(document.getElementById('editReviewModal'));
            editModal.show();
        }

        function toggleFavorite(btnElement, productId) {
            fetch('/Product/ToggleFavorite?productId=' + productId, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success === false && data.message === "require_login") {
                    let loginModalEl = document.getElementById('loginRequireModal') || document.getElementById('loginRequireFavModal');
                    if (loginModalEl) {
                        new bootstrap.Modal(loginModalEl).show();
                    } else {
                        window.location.href = "/Account/Login";
                    }
                    return;
                }
                if (data.success === true) {
                    let icon = btnElement.querySelector('i');
                    if (data.isFavorite) {
                        icon.classList.remove('far'); 
                        icon.classList.add('fas'); 
                        btnElement.classList.add('liked');
                        showToastMessage('success', 'Đã thêm vào danh sách yêu thích!');
                    } else {
                        icon.classList.remove('fas'); 
                        icon.classList.add('far'); 
                        btnElement.classList.remove('liked');
                        showToastMessage('info', 'Đã bỏ khỏi danh sách yêu thích!');
                    }
                }
            })
            .catch(error => console.error('Error:', error));
        }

        $(document).ready(function () {
            
            @if (TempData["SuccessMessage"] != null)
            {
                <text>showToastMessage('success', '@TempData["SuccessMessage"]');</text>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <text>showToastMessage('danger', '@TempData["ErrorMessage"]');</text>
            }

            $('.star-sel').hover(
                function () {
                    var val = $(this).data('val');
                    $('.star-sel').each(function () {
                        if ($(this).data('val') <= val) $(this).removeClass('far').addClass('fas');
                        else $(this).removeClass('fas').addClass('far');
                    });
                },
                function () {
                    var val = $('#ratingValue').val();
                    $('.star-sel').each(function () {
                        if ($(this).data('val') <= val) $(this).removeClass('far').addClass('fas');
                        else $(this).removeClass('fas').addClass('far');
                    });
                }
            );

            $('.star-sel').click(function () {
                var val = $(this).data('val');
                $('#ratingValue').val(val);
                $('#ratingError').addClass('d-none');
            });

            $('.edit-star-sel').hover(
                function () {
                    var val = $(this).data('val');
                    $('.edit-star-sel').each(function () {
                        if ($(this).data('val') <= val) $(this).removeClass('far').addClass('fas');
                        else $(this).removeClass('fas').addClass('far');
                    });
                },
                function () {
                    var val = $('#editRatingValue').val();
                    $('.edit-star-sel').each(function () {
                        if ($(this).data('val') <= val) $(this).removeClass('far').addClass('fas');
                        else $(this).removeClass('fas').addClass('far');
                    });
                }
            );

            $('.edit-star-sel').click(function () {
                var val = $(this).data('val');
                $('#editRatingValue').val(val);
            });

            $('#reviewForm').submit(function (e) {
                if ($('#ratingValue').val() === "0") {
                    e.preventDefault(); 
                    $('#ratingError').removeClass('d-none'); 
                }
            });

            function handleCartAction(e, button, actionName) {
                e.preventDefault(); 
                let form = document.getElementById('addToCartForm');
                let formData = new FormData(form);
                
                let originalText = button.innerHTML;
                button.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>ĐANG XỬ LÝ...';
                button.disabled = true;

                fetch('/Cart/AddToCart', {
                    method: 'POST',
                    body: formData,
                    redirect: 'follow'
                })
                .then(async response => {
                    button.innerHTML = originalText;
                    button.disabled = false;

                    if (response.redirected && response.url.toLowerCase().includes('login')) {
                        let loginModalEl = document.getElementById('loginRequireModal') || document.getElementById('loginRequireFavModal');
                        if (loginModalEl) new bootstrap.Modal(loginModalEl).show();
                        else window.location.href = response.url;
                        return;
                    }

                    let html = await response.text();
                    
                    let hasError = false;
                    let errorMessage = "Đã xảy ra lỗi, vui lòng thử lại!";

                    let errorMatch = html.match(/showToastMessage\('danger',\s*'([^']+)'\)/);
                    if (errorMatch && errorMatch[1]) {
                        hasError = true;
                        errorMessage = errorMatch[1];
                    } else {
                        let tempDoc = new DOMParser().parseFromString(html, 'text/html');
                        let alertNode = tempDoc.querySelector('.alert-danger');
                        if (alertNode) {
                            hasError = true;
                            let closeBtn = alertNode.querySelector('.btn-close');
                            if (closeBtn) closeBtn.remove();
                            errorMessage = alertNode.innerText.trim();
                        }
                    }

                    if (hasError) {
                        showToastMessage('danger', errorMessage);
                        return;
                    }

                    if (actionName === 'BuyNow') {
                        window.location.href = '/Cart/Index';
                    } else {
                        showToastMessage('success', 'Đã thêm sản phẩm vào giỏ hàng thành công!');
                        
                        let tempDoc = new DOMParser().parseFromString(html, 'text/html');
                        let newBadge = tempDoc.querySelector('.nav-item .badge.bg-danger');
                        let currentBadge = document.querySelector('.nav-item .badge.bg-danger');
                        
                        if (newBadge && currentBadge) {
                            currentBadge.innerText = newBadge.innerText;
                        } else if (currentBadge) {
                            let qtyInput = document.getElementById('quantityInput').value;
                            let currentVal = parseInt(currentBadge.innerText) || 0;
                            currentBadge.innerText = currentVal + parseInt(qtyInput);
                        }
                    }
                })
                .catch(error => {
                    button.innerHTML = originalText;
                    button.disabled = false;
                    showToastMessage('danger', 'Lỗi kết nối máy chủ!');
                });
            }

            let btnAddCart = document.getElementById('btnAddToCart');
            if(btnAddCart) {
                btnAddCart.addEventListener('click', function(e) { handleCartAction(e, this, 'AddToCart'); });
            }

            let btnBuyNow = document.getElementById('btnBuyNow');
            if(btnBuyNow) {
                btnBuyNow.addEventListener('click', function(e) { handleCartAction(e, this, 'BuyNow'); });
            }

            var selectedVariantId = '@ViewBag.SelectedVariantId';

            if (selectedVariantId && selectedVariantId !== '') {
                var productSection = document.getElementById('mainProductImage');
                if (productSection) {
                    productSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }

                setTimeout(function() {
                    let targetVariantObj = variants.find(v => v.id.toString() === selectedVariantId);
                    
                    if (targetVariantObj) {
                        for (let attrName in targetVariantObj.attributes) {
                            let attrVal = targetVariantObj.attributes[attrName];
                            
                            let allBtns = document.querySelectorAll(`.attribute-group[data-attr-name="${attrName}"] .variant-option`);
                            for (let btn of allBtns) {
                                if (btn.innerText.trim() === attrVal || (btn.innerHTML.includes('style') && btn.dataset.variantId == selectedVariantId)) {
                                    btn.click();
                                    break;
                                }
                            }
                        }
                    }
                }, 300);
            }
        });
    </script>
}