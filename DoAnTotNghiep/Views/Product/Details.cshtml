@model DoAnTotNghiep.Models.Product
@{
    ViewData["Title"] = Model.ProductName;
}

<div class="container mt-4 mb-5">

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Sản phẩm</a></li>
            <li class="breadcrumb-item active fw-bold" aria-current="page">@Model.ProductName</li>
        </ol>
    </nav>

    <div class="row bg-white p-4 shadow-sm rounded border">

        <div class="col-md-5 text-center mb-4 mb-md-0">
            <img src="@Model.ThumbnailUrl" alt="@Model.ProductName" class="img-fluid rounded" style="max-height: 450px; object-fit: contain;" />
        </div>

        <div class="col-md-7 ps-md-5">
            <h2 class="fw-bold mb-3">@Model.ProductName</h2>
            <div class="mb-3">
                <span class="badge bg-primary fs-6 me-2">📁 @Model.Category?.CategoryName</span>
                <span class="badge bg-info text-dark fs-6">🏷️ @Model.Brand?.BrandName</span>
            </div>

            <div class="mb-4">
                @if (ViewBag.ActivePromotion != null)
                {
                    var promo = ViewBag.ActivePromotion as DoAnTotNghiep.Models.Promotion;
                    var basePrice = (decimal)Model.BasePrice;
                    var salePrice = basePrice - (basePrice * promo.DiscountPercent / 100);
                    <div class="d-flex align-items-center gap-3">
                        <h2 class="text-danger fw-bold m-0">@salePrice.ToString("#,##0") đ</h2>
                        <span class="text-muted text-decoration-line-through fs-5">@basePrice.ToString("#,##0") đ</span>
                        <span class="badge bg-danger fs-6 py-2 px-3 shadow-sm rounded-pill">
                            🔥 Giảm @promo.DiscountPercent% (@promo.PromotionName)
                        </span>
                    </div>
                }
                else
                {
                    <h2 class="text-danger fw-bold m-0">@Model.BasePrice.ToString("#,##0") đ</h2>
                }
            </div>

            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                <input type="hidden" name="id" value="@Model.ProductId" />
                <div class="d-flex align-items-center mb-4">
                    <label class="fw-bold me-3">Số lượng:</label>
                    <input type="number" name="quantity" class="form-control text-center fw-bold" value="1" min="1" style="width: 100px;" />
                </div>
                <div class="d-flex gap-3 mt-4">
                    <button type="submit" class="btn btn-danger btn-lg fw-bold flex-grow-1 py-3 shadow-sm">
                        🛒 THÊM VÀO GIỎ HÀNG
                    </button>
                    <button type="submit" asp-controller="Cart" asp-action="BuyNow" class="btn btn-warning btn-lg fw-bold flex-grow-1 py-3 shadow-sm text-dark">
                        💳 MUA NGAY
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold py-3 fs-5">
                    📄 MÔ TẢ SẢN PHẨM
                </div>
                <div class="card-body p-4 lh-lg" style="font-size: 1.1rem; text-align: justify;">
                    @Html.Raw(Model.Description)
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12">
            <h3 class="fw-bold mb-4 text-uppercase border-bottom pb-2">⭐ Đánh giá sản phẩm</h3>
        </div>

        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Viết đánh giá của bạn</h5>

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger py-2">@TempData["ErrorMessage"]</div>
                    }
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success py-2">@TempData["SuccessMessage"]</div>
                    }

                    @if (User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="Product" asp-action="SubmitReview" method="post">
                            <input type="hidden" name="productId" value="@Model.ProductId" />

                            <div class="mb-3">
                                <label class="form-label fw-bold">Chất lượng sản phẩm:</label>
                                <div class="star-rating">
                                    <input type="radio" id="star5" name="rating" value="5" /><label for="star5" title="Tuyệt vời">★</label>
                                    <input type="radio" id="star4" name="rating" value="4" /><label for="star4" title="Tốt">★</label>
                                    <input type="radio" id="star3" name="rating" value="3" /><label for="star3" title="Bình thường">★</label>
                                    <input type="radio" id="star2" name="rating" value="2" /><label for="star2" title="Kém">★</label>
                                    <input type="radio" id="star1" name="rating" value="1" required /><label for="star1" title="Tệ">★</label>
                                </div>
                            </div>

                            <div class="mb-3">
                                <textarea name="comment" class="form-control" rows="4" placeholder="Hãy chia sẻ cảm nhận của bạn về sản phẩm này nhé..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary fw-bold w-100 shadow-sm">Gửi đánh giá</button>
                        </form>
                    }
                    else
                    {
                        <div class="text-center py-5 bg-white rounded border">
                            <p class="text-muted mb-3">Vui lòng đăng nhập để có thể để lại đánh giá.</p>
                            <a asp-area="" asp-controller="Account" asp-action="Login" class="btn btn-outline-primary fw-bold px-4">Đăng nhập ngay</a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-7">
            @if (Model.Reviews != null && Model.Reviews.Any(r => r.IsApproved))
            {
                var approvedReviews = Model.Reviews.Where(r => r.IsApproved).OrderByDescending(r => r.CreatedDate).ToList();

                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Lịch sử đánh giá (@approvedReviews.Count)</h5>

                        @foreach (var review in approvedReviews)
                        {
                            <div class="d-flex mb-4 pb-3 border-bottom">
                                <div class="me-3">
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold fs-5 shadow-sm" style="width: 50px; height: 50px;">
                                        @review.UserName.Substring(0, 1).ToUpper()
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="fw-bold m-0 text-dark">@review.UserName</h6>
                                        <span class="text-muted small">@review.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>

                                    <div class="text-warning mb-2" style="font-size: 1.1rem;">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= review.Rating)
                                            {
                                                <span>★</span>
                                            }
                                            else
                                            {

                                                <span class="text-muted opacity-25">★</span>
                                            }
                                        }
                                    </div>

                                    <p class="mb-0 text-secondary" style="font-size: 1.05rem;">@review.Comment</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-chat-square-text text-muted" style="font-size: 4rem;"></i>
                    <h5 class="text-muted mt-3 fw-bold">Chưa có đánh giá nào</h5>
                    <p class="text-muted">Hãy là người đầu tiên trải nghiệm và đánh giá sản phẩm này!</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            font-size: 2.2rem;
            color: #e4e5e9;
            cursor: pointer;
            transition: color 0.2s ease-in-out;
            margin-right: 5px;
        }

            .star-rating input:checked ~ label,
            .star-rating label:hover,
            .star-rating label:hover ~ label {
                color: #ffc107; 
            }
</style>