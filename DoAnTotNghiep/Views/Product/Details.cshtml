@model DoAnTotNghiep.Models.Product
@{
    ViewData["Title"] = Model.ProductName;
}
<div class="container mt-4 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Sản phẩm</a></li>
            <li class="breadcrumb-item active fw-bold" aria-current="page">@Model.ProductName</li>
        </ol>
    </nav>
    <div class="row bg-white p-4 shadow-sm rounded border">
        <div class="col-md-5 text-center mb-4 mb-md-0">
            <img src="@Model.ThumbnailUrl" alt="@Model.ProductName" class="img-fluid rounded" style="max-height: 450px; object-fit: contain;" />
        </div>
        <div class="col-md-7 ps-md-5">
            <h2 class="fw-bold mb-3">@Model.ProductName</h2>
            <div class="mb-3">
                <span class="badge bg-primary fs-6 me-2">📁 @Model.Category?.CategoryName</span>
                <span class="badge bg-info text-dark fs-6">🏷️ @Model.Brand?.BrandName</span>
            </div>
            <h2 class="text-danger fw-bold mb-4">@Model.BasePrice.ToString("#,##0") đ</h2>
            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                <input type="hidden" name="id" value="@Model.ProductId" />
                <div class="d-flex align-items-center mb-4">
                    <label class="fw-bold me-3">Số lượng:</label>
                    <input type="number" name="quantity" class="form-control text-center fw-bold" value="1" min="1" style="width: 100px;" />
                </div>
                <div class="d-flex gap-3 mt-4">
                    <button type="submit" class="btn btn-danger btn-lg fw-bold flex-grow-1 py-3 shadow-sm">
                        🛒 THÊM VÀO GIỎ HÀNG
                    </button>
                    <button type="submit" asp-controller="Cart" asp-action="BuyNow" class="btn btn-warning btn-lg fw-bold flex-grow-1 py-3 shadow-sm text-dark">
                        💳 MUA NGAY
                    </button>
                </div>
            </form>
        </div>
    </div>
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold py-3 fs-5">
                    📄 MÔ TẢ SẢN PHẨM
                </div>
                <div class="card-body p-4 lh-lg" style="font-size: 1.1rem; text-align: justify;">
                    @Html.Raw(Model.Description)
                </div>
            </div>
        </div>
    </div>
</div>