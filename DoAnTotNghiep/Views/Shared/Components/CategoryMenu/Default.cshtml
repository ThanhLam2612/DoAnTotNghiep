@model IEnumerable<DoAnTotNghiep.Models.Category>
<ul class="dropdown-menu shadow border-0" aria-labelledby="categoryDropdown">
    <li>
        <a class="dropdown-item py-2 fw-bold text-primary" asp-area="" asp-controller="Product" asp-action="Index">
            Tất cả sản phẩm
        </a>
    </li>
    <li><hr class="dropdown-divider"></li>
    @foreach (var item in Model)
    {
        <li>
            <a class="dropdown-item py-2" asp-area="" asp-controller="Product" asp-action="Index" asp-route-categoryId="@item.CategoryId">
                @item.CategoryName
            </a>
        </li>
    }
</ul>